// compiler/kel/parse.kel — the merged declaration-and-body parser (roadmap Step 2).
//
// Increment 4: a single streaming `loop` that parses a whole top-level function
// declaration whose body may now contain the `if cond { then } else { else }`
// conditional with nested statement-block branches, in one pass. Increments 1 through 3
// built the atomic body, the operator grammar, and `let` blocks; this increment brings
// body.kel's conditional machinery, including the block-form `if` statement, the `if`
// without `else`, and the pending-statement baseline that keeps a nested block's
// statements from clobbering the enclosing one. The `for`/`match` forms, data reads and
// writes, calls, and the data/enum/use declaration kinds are later increments. See
// compiler/MERGE_PLAN.md.
//
// An If node (kind 4) holds the condition in arg and the branches in lhs/rhs. A branch is
// a full statement block folded, like the body, into a cons-list. An absent `else`
// synthesizes an empty Unit branch. A completed If that a statement-starter follows was a
// statement, committed as an ExprStmt (kind 21); a terminator leaves it the block tail.
//
// Record wire and token vocabulary are unchanged from increment 2.

require word >= 32;

// The token stream is packed one token per slot in the lexer's own wire,
// `tok + payload*64` (`tok` the Tok discriminant, `payload` an Ident's interned id
// or an IntLit's value), rather than two parallel `kinds`/`vals` arrays. The shared
// segment is a flat 64KB host buffer of 8-byte words, so a two-array representation
// costs 16 bytes per token and caps input near 4000 tokens; one packed array halves
// that to 8 bytes per token, which is what lets the larger stage files fit. Each read
// site recovers `kind` as `packed % 64` and `payload` as `packed / 64`.
shared data toks {
    len: Word,
    packed: [Word; 24576],
    limit_id: Word,
    chunk_count: Word,
    chunks: [Word; 256],
    require_id: Word,
    word_id: Word,
    byte_id: Word,
    bool_id: Word,
}

// The unified token vocabulary (body.kel's `enum Tok` extended with the header keywords).
enum Tok {
    Fn = 0,
    Ident = 1,
    LBrace = 2,
    RBrace = 3,
    Yield = 5,
    Loop = 6,
    LParen = 7,
    RParen = 8,
    Colon = 9,
    Comma = 10,
    IntLit = 12,
    Data = 13,
    Shared = 14,
    Private = 15,
    Const = 16,
    Eq = 17,
    Use = 19,
    Plus = 21,
    Minus = 22,
    Star = 23,
    Slash = 24,
    Percent = 25,
    EqEq = 26,
    NotEq = 27,
    Lt = 28,
    Gt = 29,
    LtEq = 30,
    GtEq = 31,
    Not = 32,
    Band = 33,
    Bor = 34,
    Bxor = 35,
    Andalso = 36,
    Orelse = 37,
    Let = 38,
    Semi = 39,
    Dot = 40,
    If = 43,
    Else = 44,
    For = 45,
    In = 46,
    DotDot = 47,
    Match = 48,
    FatArrow = 49,
    Underscore = 50,
    LBracket = 41,
    RBracket = 42,
    ColCol = 51,
    As = 52,
    Enum = 53,
    Struct = 54,
    Trait = 55,
    Impl = 56,
    Break = 57,
    Str = 58,
}

// The node-record kinds the body walk yields (a subset of body.kel's `enum Node`).
enum Node {
    Literal = 1,
    Local = 2,
    BinOp = 3,
    If = 4,
    LetIn = 5,
    Not = 6,
    Call = 7,
    DataRead = 11,
    DataAssignIn = 12,
    IndexRead = 13,
    IndexAssignIn = 14,
    Andalso = 8,
    Orelse = 9,
    Neg = 10,
    Done = 15,
    Unit = 20,
    ExprStmt = 21,
    ForLimit = 23,
    YieldExpr = 24,
    Cast = 26,
    StructInit = 27,
    FieldAccess = 28,
    SlotRecord = 32,
    ForBuild = 33,
    MatchBuild = 34,
    FieldPos = 35,
    IndexStore = 36,
    Break = 29,
    // A flat-nested struct field read `p.f` where `f` is an array (or nested composite): emits
    // GetField(FlatNested{offset, size, variant}). Followed by an ArrIndex for `p.xs[i]`.
    FieldAccessNested = 30,
    // A flat array-element read `p.xs[i]`: emits GetIndex(Flat{element kind}). lhs = the array
    // value (a FieldAccessNested), rhs = the index expression.
    ArrIndex = 31,
    // A flat-NESTED array-element read `ps[i]` where each element is a composite (a struct): emits
    // GetIndex(FlatNested{size, variant}), extracting element i's bytes as a composite value. arg
    // packs size + variant*65536; lhs = the array value (a Local), rhs = the index. A following
    // `.field` reads into the extracted composite via the ordinary field-access postfix.
    ArrIndexNested = 43,
    // An array literal `[a, b, c]`: emits the element ops then NewComposite(Flat{Array, count,
    // byte_size}). Like a Call/StructInit, its elements ride the call_args side array.
    ArrayLit = 17,
    // An enum construction `E::V(payload...)`: emits the discriminant literal, then the payload
    // expressions, then NewComposite(Flat{Enum, count, byte_size}). The discriminant rides as
    // element 0; `count` is one (the discriminant) plus the payload field count; `byte_size` is
    // the enum's flat body size (eight for the discriminant plus the largest variant payload).
    EnumInit = 18,
    // A tuple construction `(a, b, ...)`: emits the element ops then NewComposite(Flat{Tuple,
    // count, byte_size}). Like an array literal, its elements are positional; the elements are
    // taken as `Word`-sized (byte_size = count * 8), since a mixed-scalar tuple would need
    // per-element type inference the pipeline lacks. A single `(expr)` is grouping, not a tuple.
    TupleInit = 19,
    // A tuple field read `t.N` on a tuple-typed parameter: emits GetTupleField(Flat{offset,
    // kind}), packed offset + kind * 65536, where offset/kind come from the parameter's tuple
    // type annotation (parsed into `tupledefs`). A unary node popping the parameter Local.
    TupleField = 37,
    // A string literal `"..."`: emits Const of a StaticStr pool entry. `arg` is the lexer intern
    // id of the string content, which codegen interns as a tag-1 (StaticStr) pool entry and the
    // host resolves to the string bytes. A leaf node, like a Literal.
    StrLit = 38,
    // An enum-value `match` (variant arms over an enum-typed scrutinee): lowers to the IsEnum
    // virtual loop. The built node (kind 39) reuses the `match_parts` table laid out as
    // `[temp][ename][per arm: vname, disc, result]`; `arg` the parts base, lhs the scrutinee, rhs
    // the arm count. `EnumArm` (40) is a per-arm marker record packing `vname*65536 + disc`;
    // `EnumMatchBuild` (41) is the build-signal record packing `temp + count*1024 + ename*1048576`.
    EnumMatch = 39,
    EnumArm = 40,
    EnumMatchBuild = 41,
    // A payload bind in an enum match arm pattern `E::V(x)`: a marker packing the field's flat
    // offset, ScalarKind, and the bind slot (`off + kind*65536 + slot*524288`), so codegen emits
    // `GetLocal(temp), GetEnumField(Flat{offset, kind}), SetLocal(slot)` before the arm result.
    EnumBind = 42,
}

// The shunting-yard operator codes.
enum OpCode {
    Add = 1,
    Mul = 2,
    Sub = 3,
    Div = 4,
    Mod = 5,
    Eq = 6,
    NotEq = 7,
    Lt = 8,
    Gt = 9,
    LtEq = 10,
    GtEq = 11,
    Band = 12,
    Bor = 13,
    Bxor = 14,
    Paren = 15,
    Neg = 16,
    Not = 17,
    Andalso = 18,
    Orelse = 19,
    IndexMark = 20,
    CallMark = 21,
    YieldMark = 22,
    StructMark = 23,
    ArrayMark = 24,
    EnumMark = 25,
    TupleMark = 26,
}

// The merged parser state.
private data ps {
    cursor: Word,
    mode: Word,
    dkind: Word,
    pdepth: Word,
    pdone: Word,
    pname: Word,
    ptype: Word,
    rtype: Word,
    // The chunk index (into `toks.chunks`) of the function currently being declared, so its return
    // type can be recorded in `chunkret`.
    cur_chunk: Word,
    // The return-type tuple scan `-> (T, T, ...)`: `rtts` active, `rtts_count` the element count,
    // `rtts_allword` 1 while every element so far is a `Word` (a mixed tuple is not layout-tracked).
    rtts: Word,
    rtts_count: Word,
    rtts_allword: Word,
    arr: Word,
    arr_ret: Word,
    dvis: Word,
    init: Word,
    idepth: Word,
    in_body: Word,
    started: Word,
    pend_end: Word,
    pcount: Word,
    pnames: [Word; 32],
    // Per value-parameter struct binding: 0 if not a struct type, else the struct's
    // declaration index plus one; and the field-access postfix sub-state after a struct-typed
    // parameter Local was emitted (1 awaits an optional `.`, 2 reads the field name).
    pstruct: [Word; 32],
    // Per value-parameter enum binding: 0 if not an enum type, else the enum's name intern id plus
    // one. When a `match`'s scrutinee is such a parameter, the match lowers to the IsEnum virtual
    // loop (an enum-value match) rather than an integer disc compare.
    penum: [Word; 32],
    // Per value-parameter tuple binding: 0 if not a tuple type, else the tuple layout index (in
    // `tupledefs`) plus one, so a body `t.N` access resolves the element offset/kind. `ta_phase`
    // is the tuple-access postfix sub-state (1 awaits an optional `.`, 2 reads the element index);
    // `ta_tuple` the layout index of the tuple under access. `tts`/`tts_off` scan a tuple TYPE
    // annotation `(T, T, ...)` in the signature: `tts` active, `tts_off` the running byte offset.
    ptuple: [Word; 32],
    ta_phase: Word,
    ta_tuple: Word,
    // Per value-parameter array-of-scalar binding: 0 if not an array type, else the element
    // ScalarKind plus one, so a body `xs[i]` access arms the array-index postfix and emits
    // GetIndex(Flat{kind}). Mirrors a let-bound array (`stmt.let_array`) for a parameter.
    parray: [Word; 32],
    // Per value-parameter array-of-STRUCT binding: 0 if the element is not a declared struct, else
    // the struct's declaration index plus one; `parray_size` the struct's flat byte size. A body
    // `ps[i]` extracts element i as a nested struct (GetIndex(FlatNested{size, Struct})) and a
    // following `.field` reads into it. `sa_phase`/`sa_struct`/`sa_size` are the postfix sub-state
    // after such a parameter Local was emitted (1 awaits an optional `[`).
    parray_struct: [Word; 32],
    parray_size: [Word; 32],
    sa_phase: Word,
    sa_struct: Word,
    sa_size: Word,
    // The array-access postfix after a let-bound array Local was emitted: `aa_phase` 1 awaits an
    // optional `[`, `aa_kind` the element ScalarKind for the GetIndex operand.
    aa_phase: Word,
    aa_kind: Word,
    // The tuple layout index (plus one, 0 otherwise) of the just-resolved struct field, so a
    // following `.N` on a tuple-typed field reads a tuple element.
    fa_ftuple: Word,
    // The `let`-binding index a plain-identifier lookup matched (most recent wins), so a
    // composite-typed binding can arm the field-access postfix.
    let_hit: Word,
    tts: Word,
    tts_off: Word,
    // The struct-field tuple-type scan: `tf` active while reading a `(T, T, ...)` STRUCT FIELD
    // type, `tf_size` its running byte size (summed to size the field, so a following field's
    // flat offset is correct). Distinct from `tts`, which scans a tuple PARAMETER type.
    tf: Word,
    tf_size: Word,
    fa_phase: Word,
    fa_struct: Word,
    // The just-resolved field's flat byte offset, ScalarKind (or element kind for an array),
    // and total byte size, held between reading the field name and deciding scalar (`.f`) vs
    // array-element (`.xs[i]`) access at the following token.
    fa_off: Word,
    fa_kind: Word,
    fa_size: Word,
    fa_fstruct: Word,
    found: Word,
    found_flag: Word,
    in_guard: Word,
    arm_pending: Word,
}

// The shunting-yard operator stack. `drain_reason` selects the empty-stack drain: 0 commit
// a statement at its `;`, 1 fold the block at its `}`, 2 the drained `if` condition, 3 a
// then branch's tail, 4 an else branch's tail.
private data ops {
    opstack: [Word; 64],
    opsp: Word,
    pending_op: Word,
    pending_prec: Word,
    resolving: Word,
    closing: Word,
    draining: Word,
    drain_reason: Word,
    expect_operand: Word,
}

// The statement, binding, and block-fold machinery. `pbase`/`pbase_sp`/`stmt_base` are the
// per-block pending-statement baselines pushed when a branch opens; `blockform` marks a
// just-completed block-form operand; `fold_cont` selects what the fold does when it
// finishes (0 the body's Done, 1 a then branch's phase advance, 2 an else branch's If).
private data stmt {
    let_phase: Word,
    // Set when a `break` statement was just recorded, so the terminating `;` is consumed
    // without draining a (non-existent) statement value.
    break_pending: Word,
    pending_let_name: Word,
    let_names: [Word; 64],
    scope_slot: [Word; 64],
    let_count: Word,
    slot_count: Word,
    // Per `let` binding, the composite type inferred from a DIRECT composite construction on its
    // right side, so a later `x.N`/`x.field` access on the binding resolves: `let_tuple` is 0 or
    // the tuple layout index (in `tupledefs`) plus one; `let_struct` is 0 or the struct index plus
    // one. `pending_ctuple`/`pending_cstruct` track the current `let` value's ROOT composite: a
    // construction sets one (a tuple its element count, a struct its index plus one), and any
    // operator (`emit_op`) or a call clears both, so only a bare construction root survives to the
    // `let` commit. The construction node emits last (postorder root), so the surviving value is
    // the root's type.
    let_tuple: [Word; 64],
    let_struct: [Word; 64],
    // Per `let` binding, 0 or the element ScalarKind plus one when the binding's value root was an
    // array literal, so a later `a[i]` access emits GetIndex(Flat{kind}).
    let_array: [Word; 64],
    // Per `let` binding, 0 or the element struct's declaration index plus one when the binding's
    // value root was an array-of-struct literal; `let_array_size` the element struct's byte size, so
    // a later `a[i].field` access emits GetIndex(FlatNested{size, Struct}) + a field read (the
    // let-binding analogue of an array-of-struct parameter).
    let_array_struct: [Word; 64],
    let_array_size: [Word; 64],
    // Per `let` binding, 0 or the enum's name id plus one when the binding's value root returned an
    // enum (a call of an enum-returning function), so a `match` over the binding lowers to IsEnum.
    let_enum: [Word; 64],
    pending_ctuple: Word,
    pending_cstruct: Word,
    pending_carray: Word,
    // Set at an array-of-struct literal's close: the element struct's declaration index plus one and
    // its byte size, so a `let a = [P{..}, ..]` binding records the struct-array element type.
    pending_carray_struct: Word,
    pending_carray_size: Word,
    pending_cenum: Word,
    // A block's folded-statement table. Sized to the largest stage function body: a
    // codegen.kel emitter such as `push_forlimit` is a single flat block of about 78
    // statements, so 64 is too small; 256 covers the stage files with headroom. These
    // are private (persistent-arena) slots, not part of the 64KB shared segment.
    stmt_kind: [Word; 256],
    stmt_arg: [Word; 256],
    stmt_count: Word,
    // The pending-statement and block-base stacks, sized 32 (was 16). The current stage
    // functions fit within 16, but the stage's own deepest dispatch function
    // (`step_dispatch_normal`) sits at exactly sixteen nested `if`/`else` levels, so any
    // growth of it overflows a 16-deep stack; 32 gives headroom for continued stage work.
    pstmt_kind: [Word; 32],
    pstmt_name: [Word; 32],
    pstmt_arg: [Word; 32],
    pstmt_sp: Word,
    stmt_base: Word,
    pbase: [Word; 32],
    pbase_sp: Word,
    folding: Word,
    fold_i: Word,
    fold_start: Word,
    fold_cont: Word,
    blockform: Word,
    // A monotonic sequence stamped on each block body as it opens (a then/else branch or
    // a for body). A closing `}` closes the innermost open block, which is the one with
    // the largest stamp, so nested `for` and `if` blocks close in the correct order.
    open_seq: Word,
}

// The `if`/`else` context stack: `if_phase` per pending conditional (1 condition, 2 then,
// 3 awaiting `else`, 4 awaiting the else `{`, 5 else), `if_stmt_start` its branch's
// statement baseline, `if_sp` the nesting depth.
// `if_opbase` records the operator-stack depth at each branch body's open, so the
// branch-tail fold can tell a `yield` written inside the branch (`if c { yield a }`,
// whose YieldMark sits above the base and must drain into the branch) from a `yield`
// wrapping the whole conditional (`yield if c { a }`, whose YieldMark was pushed
// before the branch opened and must keep spanning the built If).
private data branch {
    if_phase: [Word; 32],
    if_stmt_start: [Word; 32],
    if_opbase: [Word; 32],
    if_seq: [Word; 32],
    if_sp: Word,
}

// The `for v in lo..hi limit cap { body }` loop header and ForLimit emission. `for_phase`
// is the header phase (1 variable, 2 `in`, 3 low bound, 4 high bound, 5 cap, 6 opening
// `{`, 7 body); `for_var`/`for_vslot` the loop variable and its slot; `for_end_slot`/
// `for_ctr`/`for_cap_slot`/`for_oc` the ForLimit's four reserved slots; `for_cap` the
// literal cap; `forlimit_count` the emitted-loop count; `for_emit`/`for_emit_i` the
// parts-emission sub-step; `for_stmt_start` the body's statement baseline.
// The `for .. limit` context is a stack (`for_sp` deep), so a loop nested in another
// loop's body does not overwrite the enclosing loop's state. The per-loop fields (phase,
// variable, the five frame slots, the literal cap, and the body's statement start) are
// stacked; `forlimit_count` is a program-order counter and the emission cursor
// (`for_emit`/`for_emit_i`) is single because a nested loop emits its parts fully before
// the enclosing loop's body closes, so the two emissions never overlap.
private data forst {
    for_phase: [Word; 8],
    for_var: [Word; 8],
    for_vslot: [Word; 8],
    for_end_slot: [Word; 8],
    for_ctr: [Word; 8],
    for_cap_slot: [Word; 8],
    for_oc: [Word; 8],
    for_cap: [Word; 8],
    for_stmt_start: [Word; 8],
    for_seq: [Word; 8],
    for_sp: Word,
    forlimit_count: Word,
    for_emit: Word,
    for_emit_i: Word,
}

// The `match scrut { arms }` context stack: `match_phase` per pending match (1 the
// scrutinee's `{`, 2 an arm pattern, 3 the `=>`, 4 the arm result), `match_temp` the
// scrutinee's reserved temp slot, `match_argcount` the literal-arm count, `match_sp` the
// nesting depth, `match_build` the pending build signal.
private data mat {
    match_phase: [Word; 8],
    match_temp: [Word; 8],
    match_argcount: [Word; 8],
    match_sp: Word,
    match_build: Word,
    enum_phase: Word,
    enum_name: Word,
    enum_disc: Word,
    mpat_phase: Word,
    // Per open match, whether its arms are enum-variant patterns (1) so the build lowers to the
    // IsEnum virtual loop; `match_ename` the matched enum's name intern id (the IsEnum first
    // operand). `mpat_vname` the variant name id captured while reading the current arm pattern.
    match_isenum: [Word; 8],
    match_ename: [Word; 8],
    mpat_vname: Word,
    // The current arm pattern's variant row index (into `enums`) for its payload field layout, and
    // the running payload bind count (also the field cursor while reading `E::V(x, y)` binds).
    mpat_vrow: Word,
    mpat_pcount: Word,
    // The current arm's IsEnum test slot, captured at parse's slot allocation (`(`) so reconstruct
    // uses parse's slot number directly rather than recomputing a forward counter. A recomputed
    // counter cannot account for a nested match in a prior arm's result (which allocates slots
    // between the arms), so carrying parse's allocation is what makes nested enum matches work.
    mpat_tslot: Word,
    // Per open enum-value match, whether it has a `_` wildcard arm (1). The wildcard's result is
    // emitted after the variant arms and before the Trap (a catch-all), with no IsEnum test.
    match_haswc: [Word; 8],
}

// The data-field layout table, accumulated by the header as each `data` block is parsed
// (strategy B): `fdata`/`ffield` are the interned block and field names, `fbase` the
// field's element-0 slot in the flat data segment, and `flen` its slot count (1 for a
// scalar, N for an array). `base_ctr` is the running slot counter across all non-const
// blocks in declaration order; const blocks carry no runtime slots and are skipped. The
// `cur_*`/`has_field` fields hold the field under construction until its length is known
// (a scalar at its type, an array at its ASIZE), committed at the next field or the `}`.
private data fields {
    fdata: [Word; 256],
    ffield: [Word; 256],
    fbase: [Word; 256],
    flen: [Word; 256],
    field_count: Word,
    base_ctr: Word,
    cur_block: Word,
    cur_field: Word,
    cur_len: Word,
    has_field: Word,
    cur_cval: Word,
}

// The const-data field values. A `const data` block carries no runtime slot; instead each
// scalar field inlines to its integer-literal initializer, exactly as the reference
// compiler folds it to a `Const`. `cblock`/`cfield`/`cval` are the block name, field name,
// and captured value; a body read `block.field` of one emits that value as a Literal.
private data cdata {
    cblock: [Word; 256],
    cfield: [Word; 256],
    cval: [Word; 256],
    ccount: Word,
    cfound: Word,
}

// A `data.field` scalar read in the body: `da_phase` awaits the `.` (1) then the field
// name (2) then the token after the field (3); `da_data` is the block name, `da_base`/
// `da_len` the resolved field slot and length.
private data da {
    da_phase: Word,
    da_data: Word,
    da_base: Word,
    da_len: Word,
    idx_base: [Word; 8],
    idx_len: [Word; 8],
    idx_sp: Word,
    iclosing: Word,
    // Set while an open `[...]` index belongs to a struct array-field access (`p.xs[i]`) rather
    // than a data-field index, so its closing `]` emits an ArrIndex (GetIndex) of the element
    // kind instead of a data IndexRead.
    fa_index: Word,
    fa_index_kind: Word,
    // Set while an open `[...]` index belongs to an array-of-STRUCT access (`ps[i]`): the closing
    // `]` emits an ArrIndexNested (GetIndex(FlatNested{size, Struct})) instead of a scalar ArrIndex,
    // and arms the field-access postfix for the following `.field`. `fa_index_size` the element
    // struct's byte size, `fa_index_struct` its declaration index (to arm the field postfix).
    fa_index_nested: Word,
    fa_index_size: Word,
    fa_index_struct: Word,
    post_index: Word,
    pidx_base: Word,
    pidx_len: Word,
    store_emit: Word,
    store_arg: Word,
    cda_phase: Word,
    cda_block: Word,
    as_skip: Word,
}

// A function call context stack: `call_chunk`/`call_count` per pending call (the callee's
// chunk index and a running argument count), `call_sp` the nesting depth, `call_pending`
// the just-read callee name awaiting its `(`, `call_phase` that await, `cdraining` the
// per-argument operator drain at each `,`.
private data call {
    call_chunk: [Word; 8],
    call_count: [Word; 8],
    call_sp: Word,
    call_pending: Word,
    call_phase: Word,
    cdraining: Word,
    // The array-literal context stack, parallel to the call stack: `al_count` the running
    // element count per open `[...]` literal, `al_sp` the nesting depth. Its `,` drains through
    // the same `step_cdraining` (generalised to the ArrayMark), its `]` emits the ArrayLit.
    al_count: [Word; 8],
    al_sp: Word,
    // The enum-construction context stack, parallel to the call stack: `en_count` the running
    // child count per open `E::V(...)` construction (seeded at one for the discriminant, then
    // one per payload element), `en_bytesize` the enum's flat body size resolved at the open,
    // `en_sp` the nesting depth. Its `,` drains through `step_cdraining` (generalised to the
    // EnumMark), its `)` emits the EnumInit via `step_closing`.
    en_count: [Word; 8],
    en_bytesize: [Word; 8],
    // Per open enum construction, the enum's name id, so a `let e = E::A(x)` binding is tagged
    // enum-typed for a following `match e`.
    en_ename: [Word; 8],
    en_sp: Word,
    // A unit enum construction `E::V()` (no `as`) as a VALUE: after the discriminant literal is
    // emitted, `en_unit` arms the finalize that emits the count-1 EnumInit; `en_unit_bs` the enum's
    // flat body size, `en_unit_ename` its name (to tag a `let` binding enum-typed).
    en_unit: Word,
    en_unit_bs: Word,
    en_unit_ename: Word,
    // The tuple-construction context stack, parallel to the array-literal stack: `tp_count` the
    // running element count per open `(...)` tuple, `tp_sp` the nesting depth. A `(` first pushes
    // a `Paren` marker (grouping is indistinguishable until a `,`); the first top-level `,`
    // promotes it to a `TupleMark` and seeds `tp_count` at one, and the `)` emits the TupleInit.
    tp_count: [Word; 8],
    tp_sp: Word,
}

// The enum table, accumulated by the header as each `enum` block is parsed: `edata`/`evar`
// are the interned enum and variant names and `edisc` the variant's discriminant. The
// discriminant follows the implicit-increment rule (zero for the first variant, the
// previous plus one otherwise) unless an explicit `= N` overrides it and reseeds the
// running `next_disc`. `cur_enum` is the enum under construction.
private data enums {
    edata: [Word; 256],
    evar: [Word; 256],
    edisc: [Word; 256],
    // Per variant row, the sum of that variant's payload field byte sizes (zero for a unit
    // variant). A construction reads the enum's flat body size as eight (the discriminant) plus
    // the largest `epayload` across the enum's variants; see `enum_bytesize`.
    epayload: [Word; 256],
    // Per variant row, the flat per-payload-field layout for a payload match `E::V(x, y)`:
    // `evfstart`/`evfcount` bound the variant's field run in `evfoff`/`evfkind` (per-field flat
    // byte offset -- eight for the discriminant plus preceding field sizes -- and ScalarKind).
    // `evfcursor` is the running append cursor.
    evfstart: [Word; 256],
    evfcount: [Word; 256],
    evfoff: [Word; 512],
    evfkind: [Word; 512],
    evfcursor: Word,
    enum_count: Word,
    cur_enum: Word,
    next_disc: Word,
    // Scratch accumulators for `type_byte_size` (a struct payload field's size) and
    // `enum_bytesize` (the running maximum variant payload). Used transiently within each helper;
    // parse is sequential, so no reentrancy hazard.
    esz_scratch: Word,
    emax_scratch: Word,
}

// Per chunk (function, indexed as in `toks.chunks`), the composite type it returns, so a
// `let x = f()` bound to a call tags the binding like a direct construction. `ret_struct` is the
// returned struct's declaration index plus one (else 0). `ret_tuple` is the element count of an
// all-Word tuple return (>= 2, else 0), so a let-bound tuple call arms `x.N` access (all-Word
// only, matching tuple construction).
private data chunkret {
    ret_struct: [Word; 256],
    ret_tuple: [Word; 256],
    // Per chunk, the enum name id (plus one) it returns, else 0, so a `let e = f(); match e` over
    // an enum-returning call lowers to the IsEnum virtual loop.
    ret_enum: [Word; 256],
    // Per chunk, the element ScalarKind (plus one) of a scalar array return `-> [T; N]`, else 0, so
    // a `let a = f(); a[i]` bound to the call arms `a[i]` access (scalar elements only, matching the
    // scalar array-parameter and let-bound-array cases).
    ret_array: [Word; 256],
}

// The tuple-parameter-type layout table, accumulated as each `(T, T, ...)` parameter type
// annotation is scanned. `tup_estart[t]`/`tup_ecount[t]` bound tuple `t`'s element run in the
// flat `tup_eoffset`/`tup_ekind` arrays (per-element flat byte offset and ScalarKind);
// `tup_ecursor` is the running append cursor. A body `t.N` access reads element N's offset and
// kind here to bake the GetTupleField operand. Only scalar `Word`/`Byte`/`Bool` elements are
// recorded; a nested-composite tuple element would need the FlatNested form, a later increment.
private data tupledefs {
    tup_count: Word,
    tup_estart: [Word; 32],
    tup_ecount: [Word; 32],
    tup_eoffset: [Word; 256],
    tup_ekind: [Word; 256],
    tup_ecursor: Word,
}

// Struct type names, accumulated as each `struct` declaration's STRUCTSTART is emitted, so a
// body can recognise `Name { field: expr, ... }` construction. Only the names are needed to
// recognise the construction and open its field scan; the flat layout (byte size) is
// resolved downstream by the layout pass. `sc_*` is the construction context stack: `sc_sp`
// the nesting depth, `sc_name`/`sc_count` the struct name and running field count per open
// construction, `sc_pending` the just-read struct name awaiting its `{`, `sc_phase` the
// field-scan sub-state (0 none, 1 await `{`, 2 await a field name, 3 await the `:`).
private data structdefs {
    sd_count: Word,
    sd_name: [Word; 64],
    sd_bytesize: [Word; 64],
    sd_matchsz: Word,
    // The element byte size of the struct array field currently being parsed, captured at its
    // element type and multiplied by the array length at its `; N` to size the whole field.
    sd_arrelem: Word,
    // Per-struct field names in declaration order, so a construction can resolve each field to
    // its declaration POSITION and emit a FieldPos marker for reconstruct to reorder by (a
    // construction may write fields out of declaration order). `sd_fname` is the flat name
    // storage; `sd_fstart[d]`/`sd_fcount[d]` bound struct d's field-name run; `sd_fname_ctr`
    // is the running append cursor; `sc_fieldpos` is the just-resolved construction position.
    sd_fstart: [Word; 64],
    sd_fcount: [Word; 64],
    sd_fname: [Word; 512],
    sd_foffset: [Word; 512],
    sd_fkind: [Word; 512],
    // Each field's total flat byte size (a scalar's kind size, an array's element*length, a
    // nested struct's own size), so an array-element access `p.xs[i]` can emit the FlatNested
    // GetField that extracts the whole array field before indexing it.
    sd_fsize: [Word; 512],
    // For a struct-typed field, the nested struct's declaration index plus one (0 for a scalar
    // or array field), so a nested field access `p.inner.x` can resolve the inner field.
    sd_fstruct: [Word; 512],
    // For a tuple-typed field, the `tupledefs` layout index plus one (0 otherwise), so a nested
    // tuple-element access `s.p.N` can extract the tuple field (FlatNested{Tuple}) then read
    // element N (GetTupleField).
    sd_ftuple: [Word; 512],
    sd_fname_ctr: Word,
    sc_fieldpos: Word,
    sc_sp: Word,
    sc_name: [Word; 8],
    sc_count: [Word; 8],
    sc_pending: Word,
    sc_phase: Word,
    sc_closing: Word,
}

// Resolve an identifier to its frame slot: the `let` bindings first (most recent wins),
// then the parameters.
fn step_local(v: Word) -> Word {
    ps.found = 0;
    ps.found_flag = 0;
    for i in 0..stmt.let_count limit 64 {
        if stmt.let_names[i] == v {
            ps.found = stmt.scope_slot[i];
            ps.found_flag = 1;
        }
    }
    if ps.found_flag == 0 {
        for i in 0..ps.pcount limit 32 {
            if ps.pnames[i] == v {
                ps.found = i;
            }
        }
    }
    ops.expect_operand = 0;
    Node::Local() as Word + ps.found * 64
}

// Resolve a plain identifier that is neither a chunk, data block, const block, enum, nor
// struct name. If it is a struct-typed PARAMETER not shadowed by a `let` binding, emit its
// Local and arm the field-access postfix (a following `.f` becomes a FieldAccess); a `let`
// binding (whose struct type is not tracked) and a non-struct parameter both read as an
// ordinary Local. Held in its own function so step_ident's five-deep name-lookup chain is not
// deepened by the two scan loops here (the parser's own conditional stack is bounded).
fn resolve_plain_ident(v: Word) -> Word {
    ps.found_flag = 0;
    ps.let_hit = 0;
    for i in 0..stmt.let_count limit 64 {
        if stmt.let_names[i] == v {
            ps.found_flag = 1;
            ps.let_hit = i;
        }
    }
    if ps.found_flag == 1 {
        // A `let` binding: if its value's root was a composite construction, arm the field-access
        // postfix (a tuple binding arms `t.N`, a struct binding arms `x.field`); otherwise read it
        // as an ordinary Local.
        if stmt.let_tuple[ps.let_hit] > 0 {
            ps.ta_tuple = stmt.let_tuple[ps.let_hit] - 1;
            ps.ta_phase = 1;
            ops.expect_operand = 0;
            Node::Local() as Word + stmt.scope_slot[ps.let_hit] * 64
        } else {
        if stmt.let_struct[ps.let_hit] > 0 {
            ps.fa_struct = stmt.let_struct[ps.let_hit] - 1;
            ps.fa_phase = 1;
            ops.expect_operand = 0;
            Node::Local() as Word + stmt.scope_slot[ps.let_hit] * 64
        } else {
        if stmt.let_array_struct[ps.let_hit] > 0 {
            // A let-bound array-of-struct: arm the struct-array postfix (a following `[i]` emits
            // GetIndex(FlatNested{size, Struct}) and arms `.field` access into the element), the
            // let-binding analogue of an array-of-struct parameter.
            ps.sa_struct = stmt.let_array_struct[ps.let_hit] - 1;
            ps.sa_size = stmt.let_array_size[ps.let_hit];
            ps.sa_phase = 1;
            ops.expect_operand = 0;
            Node::Local() as Word + stmt.scope_slot[ps.let_hit] * 64
        } else {
        if stmt.let_array[ps.let_hit] > 0 {
            ps.aa_kind = stmt.let_array[ps.let_hit] - 1;
            ps.aa_phase = 1;
            ops.expect_operand = 0;
            Node::Local() as Word + stmt.scope_slot[ps.let_hit] * 64
        } else {
            // An enum-typed `let` binding serving as a `match` scrutinee (the open match is in its
            // scrutinee phase 1) marks that match an enum-value match, so it lowers to the IsEnum
            // loop; the binding still reads as a plain Local.
            if stmt.let_enum[ps.let_hit] > 0 andalso mat.match_sp > 0 andalso mat.match_phase[mat.match_sp - 1] == 1 {
                mat.match_isenum[mat.match_sp - 1] = 1;
                mat.match_ename[mat.match_sp - 1] = stmt.let_enum[ps.let_hit] - 1;
            }
            step_local(v)
        } } } }
    } else {
        ps.found_flag = 0;
        for i in 0..ps.pcount limit 32 {
            if ps.pnames[i] == v andalso ps.pstruct[i] > 0 {
                ps.found_flag = 1;
                ps.found = i;
                ps.fa_struct = ps.pstruct[i] - 1;
            }
        }
        if ps.found_flag == 1 {
            ps.fa_phase = 1;
            ops.expect_operand = 0;
            Node::Local() as Word + ps.found * 64
        } else {
            ps.found_flag = 0;
            for i in 0..ps.pcount limit 32 {
                if ps.pnames[i] == v andalso ps.ptuple[i] > 0 {
                    ps.found_flag = 1;
                    ps.found = i;
                    ps.ta_tuple = ps.ptuple[i] - 1;
                }
            }
            if ps.found_flag == 1 {
                ps.ta_phase = 1;
                ops.expect_operand = 0;
                Node::Local() as Word + ps.found * 64
            } else {
                ps.found_flag = 0;
                for i in 0..ps.pcount limit 32 {
                    if ps.pnames[i] == v andalso ps.parray_struct[i] > 0 {
                        ps.found_flag = 1;
                        ps.found = i;
                        ps.sa_struct = ps.parray_struct[i] - 1;
                        ps.sa_size = ps.parray_size[i];
                    }
                }
                if ps.found_flag == 1 {
                    // An array-of-struct parameter: arm the struct-array-index postfix (a following
                    // `[i]` emits GetIndex(FlatNested{size, Struct}) and arms `.field` access into
                    // the extracted element); the parameter reads as its Local, indexed whole.
                    ps.sa_phase = 1;
                    ops.expect_operand = 0;
                    Node::Local() as Word + ps.found * 64
                } else {
                ps.found_flag = 0;
                for i in 0..ps.pcount limit 32 {
                    if ps.pnames[i] == v andalso ps.parray[i] > 0 {
                        ps.found_flag = 1;
                        ps.found = i;
                        ps.aa_kind = ps.parray[i] - 1;
                    }
                }
                if ps.found_flag == 1 {
                    // A scalar array parameter: arm the array-index postfix (a following `[i]` emits
                    // GetIndex(Flat{kind})); the parameter reads as its Local, indexed whole.
                    ps.aa_phase = 1;
                    ops.expect_operand = 0;
                    Node::Local() as Word + ps.found * 64
                } else {
                    // A non-struct, non-tuple, non-array parameter. If it is an enum-typed parameter
                    // serving as a `match` scrutinee (the open match is in its scrutinee phase 1),
                    // mark that match an enum-value match so it lowers to the IsEnum loop; the
                    // parameter still reads as a plain Local.
                    for i in 0..ps.pcount limit 32 {
                        if ps.pnames[i] == v andalso ps.penum[i] > 0 andalso mat.match_sp > 0 andalso mat.match_phase[mat.match_sp - 1] == 1 {
                            mat.match_isenum[mat.match_sp - 1] = 1;
                            mat.match_ename[mat.match_sp - 1] = ps.penum[i] - 1;
                        }
                    }
                    step_local(v)
                }
                }
            }
        }
    }
}

// An identifier in operand position: a chunk (function) name opens a call, a data-block
// name a `data.field` read; any other identifier is a Local (a `let` binding or a
// parameter).
fn step_ident(v: Word) -> Word {
    ps.found_flag = 0;
    for i in 0..toks.chunk_count limit 256 {
        if toks.chunks[i] == v {
            call.call_pending = i;
            ps.found_flag = 1;
        }
    }
    if ps.found_flag == 1 {
        call.call_phase = 1;
        0
    } else {
    ps.found_flag = 0;
    for i in 0..fields.field_count limit 256 {
        if fields.fdata[i] == v {
            ps.found_flag = 1;
        }
    }
    if ps.found_flag == 1 {
        da.da_data = v;
        da.da_phase = 1;
        0
    } else {
    ps.found_flag = 0;
    for i in 0..cdata.ccount limit 256 {
        if cdata.cblock[i] == v {
            ps.found_flag = 1;
        }
    }
    if ps.found_flag == 1 {
        // A const-data block name opens a `block.field` read that inlines to a Literal.
        da.cda_block = v;
        da.cda_phase = 1;
        0
    } else {
    ps.found_flag = 0;
    for i in 0..enums.enum_count limit 256 {
        if enums.edata[i] == v {
            ps.found_flag = 1;
        }
    }
    if ps.found_flag == 1 {
        // An enum name opens a `Name::Variant() as Word` cast folded to the discriminant.
        mat.enum_name = v;
        mat.enum_phase = 1;
        0
    } else {
    ps.found_flag = 0;
    for i in 0..structdefs.sd_count limit 64 {
        if structdefs.sd_name[i] == v {
            ps.found_flag = 1;
            // Record the struct's declaration index; the StructInit node carries it so the
            // layout bridge can resolve the struct's flat byte size downstream.
            structdefs.sc_pending = i;
        }
    }
    if ps.found_flag == 1 {
        // A struct type name opens a `Name { field: expr, ... }` construction; await the `{`.
        structdefs.sc_phase = 1;
        0
    } else {
        resolve_plain_ident(v)
    } } } } }
}

// A const-data field name: look its value up in the const-field table and emit it as a
// Literal, exactly as the reference compiler inlines a const-data read. Const fields are
// scalar and immutable, so no index or assignment lookahead follows.
fn step_cfield(k: Word, v: Word) -> Word {
    da.cda_phase = 0;
    if k == 1 {
        cdata.cfound = 0;
        for i in 0..cdata.ccount limit 256 {
            if cdata.cblock[i] == da.cda_block andalso cdata.cfield[i] == v {
                cdata.cfound = cdata.cval[i];
            }
        }
        ops.expect_operand = 0;
        Node::Literal() as Word + cdata.cfound * 64
    } else {
        0
    }
}

// The flat byte size of a payload field type: a `Word` eight bytes, a `Byte`/`Bool` one, a
// struct type its accumulated flat body size (zero for an unrecognised name). Mirrors
// `field_size_and_kind` without recording a ScalarKind, as an enum payload's per-field kind is
// unused until payload matching lands.
fn type_byte_size(v: Word) -> Word {
    if v == toks.word_id {
        8
    } else {
    if v == toks.byte_id {
        1
    } else {
    if v == toks.bool_id {
        1
    } else {
        enums.esz_scratch = 0;
        for i in 0..structdefs.sd_count limit 64 {
            if structdefs.sd_name[i] == v {
                enums.esz_scratch = structdefs.sd_bytesize[i];
            }
        }
        enums.esz_scratch
    } } }
}

// The ScalarKind tag of a scalar type name: `Word` Int (3), `Byte` (2), `Bool` (1), else Unit
// (0). Used to bake a tuple element's GetTupleField kind, mirroring `field_size_and_kind`'s tag.
fn scalar_kind_of(v: Word) -> Word {
    if v == toks.word_id {
        3
    } else {
    if v == toks.byte_id {
        2
    } else {
    if v == toks.bool_id {
        1
    } else {
        0
    } } }
}

// A token inside a return-type tuple `-> (T, T, ...)` during the signature scan. Counts the
// elements and tracks whether all are `Word`; the `)` records the count for the current chunk (so
// a let bound to a call of this function arms `x.N` access) only when the tuple is all-Word. Emits
// no signature record, matching the prior (skipped) handling of a tuple return type.
fn step_ret_tuple_type(k: Word, v: Word) -> Word {
    if k == Tok::Ident() as Word {
        ps.rtts_count = ps.rtts_count + 1;
        if v != toks.word_id {
            ps.rtts_allword = 0;
        }
        0
    } else {
    if k == Tok::RParen() as Word {
        if ps.rtts_allword == 1 {
            chunkret.ret_tuple[ps.cur_chunk] = ps.rtts_count;
        }
        ps.rtts = 0;
        ps.rtype = 0;
        0
    } else {
        0
    } }
}

// A token inside a tuple parameter type `(T, T, ...)` during the signature scan. A type ident
// records the element's running flat byte offset and ScalarKind into the current tuple layout;
// the `)` advances the flat element cursor and ends the scan. A `,` (and any other token) is
// ignored. Emits no signature record.
fn step_tuple_type(k: Word, v: Word) -> Word {
    if k == Tok::Ident() as Word {
        let li = ps.ptuple[ps.pcount - 1] - 1;
        let base = tupledefs.tup_estart[li];
        let ei = tupledefs.tup_ecount[li];
        tupledefs.tup_eoffset[base + ei] = ps.tts_off;
        tupledefs.tup_ekind[base + ei] = scalar_kind_of(v);
        tupledefs.tup_ecount[li] = ei + 1;
        ps.tts_off = ps.tts_off + type_byte_size(v);
        0
    } else {
    if k == Tok::RParen() as Word {
        let li = ps.ptuple[ps.pcount - 1] - 1;
        tupledefs.tup_ecursor = tupledefs.tup_estart[li] + tupledefs.tup_ecount[li];
        ps.tts = 0;
        ps.ptype = 0;
        0
    } else {
        0
    } }
}

// The flat body size of an enum: eight bytes for the discriminant plus the largest payload
// across the enum's variants. A construction of any variant carries this same size, matching
// the reference (every variant of an enum shares the enum's flat footprint).
fn enum_bytesize(name: Word) -> Word {
    enums.emax_scratch = 0;
    for i in 0..enums.enum_count limit 256 {
        if enums.edata[i] == name andalso enums.epayload[i] > enums.emax_scratch {
            enums.emax_scratch = enums.epayload[i];
        }
    }
    8 + enums.emax_scratch
}

// A `Name::Variant() as Word` cast, folded to the variant's discriminant literal. Phase 1
// awaits `::`, phase 2 the variant (whose discriminant is looked up in the enum table),
// phase 3 the `(`, phase 4 the `)`, phase 5 the `as`, phase 6 the target type, after which
// a Literal carrying the discriminant is emitted. A phase-4 token other than `)` is a payload
// construction `E::V(expr, ...)`: emit the discriminant as element 0, open an EnumMark context,
// and re-dispatch the token so the payload parses normally (closed by `step_closing`).
fn step_enum(k: Word, v: Word) -> Word {
    if mat.enum_phase == 1 {
        if k == Tok::ColCol() as Word {
            mat.enum_phase = 2;
        }
        0
    } else {
    if mat.enum_phase == 2 {
        if k == Tok::Ident() as Word {
            mat.enum_disc = 0;
            for i in 0..enums.enum_count limit 256 {
                if enums.edata[i] == mat.enum_name andalso enums.evar[i] == v {
                    mat.enum_disc = enums.edisc[i];
                }
            }
            mat.enum_phase = 3;
        }
        0
    } else {
    if mat.enum_phase == 3 {
        if k == Tok::LParen() as Word {
            mat.enum_phase = 4;
        }
        0
    } else {
    if mat.enum_phase == 4 {
        if k == Tok::RParen() as Word {
            mat.enum_phase = 5;
            0
        } else {
            // A payload construction `E::V(expr, ...)`. Emit the discriminant literal now (element
            // 0), open an EnumMark context seeded at one child (the discriminant) with the enum's
            // flat body size, and re-dispatch this first payload token through the normal path.
            mat.enum_phase = 0;
            call.en_count[call.en_sp] = 1;
            call.en_bytesize[call.en_sp] = enum_bytesize(mat.enum_name);
            call.en_ename[call.en_sp] = mat.enum_name;
            call.en_sp = call.en_sp + 1;
            ops.opstack[ops.opsp] = OpCode::EnumMark() as Word;
            ops.opsp = ops.opsp + 1;
            ops.expect_operand = 1;
            ps.cursor = ps.cursor - 1;
            Node::Literal() as Word + mat.enum_disc * 64
        }
    } else {
    if mat.enum_phase == 5 {
        if k == Tok::As() as Word {
            mat.enum_phase = 6;
            0
        } else {
            // Not `as`: `E::V()` is a unit enum construction as a VALUE. Emit the discriminant
            // literal (element 0), arm the count-1 EnumInit finalize, and push this token back.
            mat.enum_phase = 0;
            call.en_unit = 1;
            call.en_unit_bs = enum_bytesize(mat.enum_name);
            call.en_unit_ename = mat.enum_name;
            ps.cursor = ps.cursor - 1;
            ops.expect_operand = 0;
            Node::Literal() as Word + mat.enum_disc * 64
        }
    } else {
        mat.enum_phase = 0;
        ops.expect_operand = 0;
        Node::Literal() as Word + mat.enum_disc * 64
    } } } } }
}

// Finalize a unit enum construction `E::V()`: after its discriminant literal, emit the count-1
// EnumInit (NewComposite(Flat{Enum, count 1, byte_size})) and tag the pending composite type with
// the enum so a `let e = E::V()` binding is enum-typed for a following `match e`.
fn step_enum_unit_finalize() -> Word {
    call.en_unit = 0;
    ops.expect_operand = 0;
    stmt.pending_ctuple = 0;
    stmt.pending_cstruct = 0;
    stmt.pending_carray = 0;
    stmt.pending_carray_struct = 0;
    stmt.pending_cenum = call.en_unit_ename + 1;
    Node::EnumInit() as Word + (call.en_unit_bs * 1024 + 1) * 64
}

// The `::Variant()` of a unit enum-variant match pattern, folded to the variant's
// discriminant literal. Phase 1 awaits `::`, phase 2 the variant, phase 3 the `(`, phase 4
// the `)`, after which the discriminant Literal is emitted as the arm's pattern and the arm
// advances to its `=>`, exactly as an integer-literal arm would.
fn step_mpat(k: Word, v: Word) -> Word {
    if mat.mpat_phase == 1 {
        if k == Tok::ColCol() as Word {
            mat.mpat_phase = 2;
        }
        0
    } else {
    if mat.mpat_phase == 2 {
        if k == Tok::Ident() as Word {
            mat.mpat_vname = v;
            mat.enum_disc = 0;
            mat.mpat_vrow = 0;
            for i in 0..enums.enum_count limit 256 {
                if enums.edata[i] == mat.enum_name andalso enums.evar[i] == v {
                    mat.enum_disc = enums.edisc[i];
                    mat.mpat_vrow = i;
                }
            }
            mat.mpat_phase = 3;
        }
        0
    } else {
    if mat.mpat_phase == 3 {
        if k == Tok::LParen() as Word {
            mat.mpat_phase = 4;
            if mat.match_isenum[mat.match_sp - 1] == 1 {
                // Reserve this arm's IsEnum test slot before its payload bind slots, so parse's
                // slot numbers match codegen's allocation (temp, then per arm: test, binds).
                // Capture the slot number so reconstruct emits it directly (see `mpat_tslot`).
                mat.mpat_tslot = ps.pcount + stmt.slot_count;
                stmt.slot_count = stmt.slot_count + 1;
                mat.mpat_pcount = 0;
            }
        }
        0
    } else {
        if mat.match_isenum[mat.match_sp - 1] == 1 andalso k == Tok::Ident() as Word {
            // A payload bind variable `x` in `E::V(x)`: allocate its frame slot, register it as a
            // let binding so the arm result resolves it, look up the field's flat offset and kind
            // from the variant layout, and emit an EnumBind marker.
            let slot = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            stmt.let_names[stmt.let_count] = v;
            stmt.scope_slot[stmt.let_count] = slot;
            stmt.let_tuple[stmt.let_count] = 0;
            stmt.let_struct[stmt.let_count] = 0;
            stmt.let_array[stmt.let_count] = 0;
            stmt.let_count = stmt.let_count + 1;
            let fi = enums.evfstart[mat.mpat_vrow] + mat.mpat_pcount;
            mat.mpat_pcount = mat.mpat_pcount + 1;
            Node::EnumBind() as Word + (enums.evfoff[fi] + enums.evfkind[fi] * 65536 + slot * 524288) * 64
        } else {
        if k == Tok::Comma() as Word {
            0
        } else {
            // `)`: the pattern is complete.
            mat.mpat_phase = 0;
            mat.match_argcount[mat.match_sp - 1] = mat.match_argcount[mat.match_sp - 1] + 1;
            mat.match_phase[mat.match_sp - 1] = 3;
            if mat.match_isenum[mat.match_sp - 1] == 1 {
                // Emit an EnumArm marker packing the variant name, discriminant, payload bind
                // count, and parse-allocated test slot for the IsEnum lowering; the arm result
                // follows. The test slot is carried (not recomputed in reconstruct) so a nested
                // match in a prior arm's result cannot desynchronize the arm test slots.
                Node::EnumArm() as Word + (((mat.mpat_vname * 65536 + mat.enum_disc) * 8 + mat.mpat_pcount) * 1024 + mat.mpat_tslot) * 64
            } else {
                Node::Literal() as Word + mat.enum_disc * 64
            }
        } }
    } } }
}

// The data-field name: resolve `da_data.field` to its element-0 slot and length in the
// accumulated table, then await the token after the field.
fn step_dafield(k: Word, v: Word) -> Word {
    if k == 1 {
        da.da_base = 0;
        da.da_len = 1;
        for i in 0..fields.field_count limit 256 {
            if fields.fdata[i] == da.da_data andalso fields.ffield[i] == v {
                da.da_base = fields.fbase[i];
                da.da_len = fields.flen[i];
            }
        }
        da.da_phase = 3;
    }
    0
}

// The token after a data field: a `[` opens an indexed access (push the field's base and
// length on the idx stack and an index marker that blocks precedence across the index),
// a `=` a scalar assignment (target = the field's slot), any other token a scalar read.
fn step_daindex(k: Word) -> Word {
    if k == Tok::LBracket() as Word {
        da.idx_base[da.idx_sp] = da.da_base;
        da.idx_len[da.idx_sp] = da.da_len;
        da.idx_sp = da.idx_sp + 1;
        ops.opstack[ops.opsp] = OpCode::IndexMark() as Word;
        ops.opsp = ops.opsp + 1;
        da.da_phase = 0;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Eq() as Word {
        stmt.pstmt_kind[stmt.pstmt_sp] = 1;
        stmt.pstmt_arg[stmt.pstmt_sp] = da.da_base;
        stmt.pstmt_sp = stmt.pstmt_sp + 1;
        da.da_phase = 0;
        ops.expect_operand = 1;
        0
    } else {
        ps.cursor = ps.cursor - 1;
        da.da_phase = 0;
        ops.expect_operand = 0;
        Node::DataRead() as Word + da.da_base * 64
    } }
}

// A `]`: flush the operators above the index marker, then pop the marker and the idx
// stack into a one-slot lookahead (pidx). The IndexRead is not emitted yet: the token
// after the `]` decides between a read and an indexed assignment.
fn step_iclosing() -> Word {
    if ops.opsp > 0 andalso ops.opstack[ops.opsp - 1] != OpCode::IndexMark() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::ArrayMark() as Word {
        ops.opsp = ops.opsp - 1;
        let op = ops.opstack[ops.opsp];
        emit_op(op)
    } else {
        da.iclosing = 0;
        if ops.opstack[ops.opsp - 1] == OpCode::ArrayMark() as Word {
            // An array literal `[...]` close: pop the ArrayMark, count the last element (unless
            // the array is empty, when no value was parsed), pop the array context, and emit an
            // ArrayLit packing the flat byte size (count * word_bytes, eight per Word element)
            // and the count as byte_size * 1024 + count -- the reconstruct/StructInit shape --
            // which codegen lowers to NewComposite(Flat{Array, count, byte_size}).
            ops.opsp = ops.opsp - 1;
            if ops.expect_operand == 0 {
                call.al_count[call.al_sp - 1] = call.al_count[call.al_sp - 1] + 1;
            }
            let count = call.al_count[call.al_sp - 1];
            call.al_sp = call.al_sp - 1;
            ops.expect_operand = 0;
            // Record this array as the value's current root composite so a `let` binding to it can
            // arm `a[i]` access; a later operator/call clears it. If the last element was a struct
            // construction (pending_cstruct set), the array is an array-of-struct: its element size
            // is the struct's byte size (so byte_size = count * element_size, not count * 8) and the
            // binding records the element struct type. Otherwise the elements are all-Word (element
            // ScalarKind Int = 3, byte_size = count * 8).
            let elem_struct = stmt.pending_cstruct;
            stmt.pending_ctuple = 0;
            stmt.pending_cstruct = 0;
            stmt.pending_carray_struct = 0;
            stmt.pending_carray_size = 0;
            stmt.pending_cenum = 0;
            if elem_struct > 0 {
                let esize = structdefs.sd_bytesize[elem_struct - 1];
                stmt.pending_carray = 0;
                stmt.pending_carray_struct = elem_struct;
                stmt.pending_carray_size = esize;
                Node::ArrayLit() as Word + (count * esize * 1024 + count) * 64
            } else {
                stmt.pending_carray = 3 + 1;
                Node::ArrayLit() as Word + (count * 8 * 1024 + count) * 64
            }
        } else {
            ops.opsp = ops.opsp - 1;
            if da.fa_index == 1 {
                // An array-element access. A struct-element array (`ps[i]`, `fa_index_nested`)
                // emits an ArrIndexNested (GetIndex(FlatNested{size, Struct}), variant Struct = 2)
                // and arms the field-access postfix so a following `.field` reads into the extracted
                // element; a scalar-element array (`xs[i]`/`p.xs[i]`) emits a scalar ArrIndex of the
                // element kind. Both pop the index (top) and the array value. No read-vs-assign
                // lookahead (array-element assignment is a later increment).
                da.fa_index = 0;
                ops.expect_operand = 0;
                if da.fa_index_nested == 1 {
                    da.fa_index_nested = 0;
                    ps.fa_phase = 1;
                    ps.fa_struct = da.fa_index_struct;
                    Node::ArrIndexNested() as Word + (da.fa_index_size + 2 * 65536) * 64
                } else {
                    Node::ArrIndex() as Word + da.fa_index_kind * 64
                }
            } else {
                da.idx_sp = da.idx_sp - 1;
                da.pidx_base = da.idx_base[da.idx_sp];
                da.pidx_len = da.idx_len[da.idx_sp];
                da.post_index = 1;
                0
            }
        }
    }
}

// The token after a closing `]`. A `=` makes the just-indexed `d.f[i]` an assignment
// target: push a pending indexed assignment (pstmt kind 2, carrying base + len*2^24),
// leaving the index node on the host stack for the eventual IndexStore. Any other token is
// a read: emit the IndexRead (kind 13) over the index node and push the token back.
// The base and length pack with a 2^24 radix (not 2^16) so a data array in a shared
// segment beyond 64 KB, whose element-0 slot or length exceeds 65535, does not spill
// its base into the length field; the runtime's `GetDataIndexed` operands are the
// matching twenty-four bits.
fn step_post_index(k: Word) -> Word {
    da.post_index = 0;
    if k == Tok::Eq() as Word {
        stmt.pstmt_kind[stmt.pstmt_sp] = 2;
        stmt.pstmt_arg[stmt.pstmt_sp] = da.pidx_base + da.pidx_len * 16777216;
        stmt.pstmt_sp = stmt.pstmt_sp + 1;
        ops.expect_operand = 1;
        0
    } else {
        ps.cursor = ps.cursor - 1;
        ops.expect_operand = 0;
        Node::IndexRead() as Word + (da.pidx_base + da.pidx_len * 16777216) * 64
    }
}

// After the IndexStore signal, record the IndexAssignIn statement so the block fold wraps
// the store node as the assignment.
fn step_store_finalize() -> Word {
    da.store_emit = 0;
    stmt.stmt_kind[stmt.stmt_count] = Node::IndexAssignIn() as Word;
    stmt.stmt_arg[stmt.stmt_count] = da.store_arg;
    stmt.stmt_count = stmt.stmt_count + 1;
    ops.expect_operand = 1;
    0
}

fn prec_of(op: Word) -> Word {
    match op {
        OpCode::Neg() => 9,
        OpCode::Not() => 9,
        OpCode::Paren() => 0,
        OpCode::IndexMark() => 0,
        OpCode::YieldMark() => 0,
        // The call- and struct-construction marks are grouping markers too: an operator's
        // precedence resolution must never pop them (they are consumed by the closing `)` or
        // `}`), so they carry precedence 0. Without this a default-precedence operator such as
        // a comparison in a call argument (`f(a > b)`) pops the CallMark and mis-emits it.
        OpCode::CallMark() => 0,
        OpCode::StructMark() => 0,
        OpCode::ArrayMark() => 0,
        OpCode::EnumMark() => 0,
        OpCode::TupleMark() => 0,
        OpCode::Mul() => 8,
        OpCode::Div() => 8,
        OpCode::Mod() => 8,
        OpCode::Add() => 7,
        OpCode::Sub() => 7,
        OpCode::Band() => 6,
        OpCode::Bxor() => 5,
        OpCode::Bor() => 4,
        OpCode::Andalso() => 2,
        OpCode::Orelse() => 1,
        _ => 3,
    }
}

fn emit_op(op: Word) -> Word {
    // Any operator applied to a `let` value's operand means the value's root is not a bare
    // composite construction, so clear the pending composite-type tracking (see `stmt`).
    stmt.pending_ctuple = 0;
    stmt.pending_cstruct = 0;
    stmt.pending_carray = 0;
    stmt.pending_carray_struct = 0;
    stmt.pending_cenum = 0;
    match op {
        OpCode::Neg() => Node::Neg() as Word,
        OpCode::Not() => Node::Not() as Word,
        OpCode::Andalso() => Node::Andalso() as Word,
        OpCode::Orelse() => Node::Orelse() as Word,
        OpCode::YieldMark() => Node::YieldExpr() as Word,
        _ => Node::BinOp() as Word + op * 64,
    }
}

fn opcode_of(k: Word) -> Word {
    match k {
        Tok::Plus() => OpCode::Add() as Word,
        Tok::Minus() => OpCode::Sub() as Word,
        Tok::Star() => OpCode::Mul() as Word,
        Tok::Slash() => OpCode::Div() as Word,
        Tok::Percent() => OpCode::Mod() as Word,
        Tok::EqEq() => OpCode::Eq() as Word,
        Tok::NotEq() => OpCode::NotEq() as Word,
        Tok::Lt() => OpCode::Lt() as Word,
        Tok::Gt() => OpCode::Gt() as Word,
        Tok::LtEq() => OpCode::LtEq() as Word,
        Tok::GtEq() => OpCode::GtEq() as Word,
        Tok::Band() => OpCode::Band() as Word,
        Tok::Bor() => OpCode::Bor() as Word,
        Tok::Bxor() => OpCode::Bxor() as Word,
        Tok::Andalso() => OpCode::Andalso() as Word,
        Tok::Orelse() => OpCode::Orelse() as Word,
        _ => 0,
    }
}

fn step_resolving() -> Word {
    if ops.opsp > 0 andalso prec_of(ops.opstack[ops.opsp - 1]) >= ops.pending_prec {
        ops.opsp = ops.opsp - 1;
        let op = ops.opstack[ops.opsp];
        emit_op(op)
    } else {
        ops.opstack[ops.opsp] = ops.pending_op;
        ops.opsp = ops.opsp + 1;
        ops.resolving = 0;
        0
    }
}

// A `)`: flush the operators above the marker. A parenthesis marker is discarded; a call
// marker counts the last argument (when one is present) and emits the Call.
fn step_closing() -> Word {
    if ops.opsp > 0 {
        let top = ops.opstack[ops.opsp - 1];
        if top == OpCode::Paren() as Word {
            ops.opsp = ops.opsp - 1;
            ops.closing = 0;
            ops.expect_operand = 0;
            0
        } else {
        if top == OpCode::CallMark() as Word {
            ops.opsp = ops.opsp - 1;
            ops.closing = 0;
            if ops.expect_operand == 0 {
                call.call_count[call.call_sp - 1] = call.call_count[call.call_sp - 1] + 1;
            }
            call.call_sp = call.call_sp - 1;
            ops.expect_operand = 0;
            // A call is the value's root: set the pending composite type to the callee's struct,
            // all-Word-tuple, enum, or scalar-array return type (0 otherwise), so a `let x = f()`
            // bound to the call tags the binding and `x.field`/`x.N`/`x[i]`/`match x` resolves.
            stmt.pending_ctuple = chunkret.ret_tuple[call.call_chunk[call.call_sp]];
            stmt.pending_cstruct = chunkret.ret_struct[call.call_chunk[call.call_sp]];
            stmt.pending_carray = chunkret.ret_array[call.call_chunk[call.call_sp]];
            stmt.pending_carray_struct = 0;
            stmt.pending_cenum = chunkret.ret_enum[call.call_chunk[call.call_sp]];
            Node::Call() as Word + (call.call_chunk[call.call_sp] + call.call_count[call.call_sp] * 256) * 64
        } else {
        if top == OpCode::EnumMark() as Word {
            // A `)` closing an enum payload construction: pop the mark, count the last payload
            // element (when a value was parsed), and emit the EnumInit packing the enum's flat
            // byte size and the child count as `byte_size * 1024 + count` -- the StructInit/
            // ArrayLit shape reconstruct consumes.
            ops.opsp = ops.opsp - 1;
            ops.closing = 0;
            if ops.expect_operand == 0 {
                call.en_count[call.en_sp - 1] = call.en_count[call.en_sp - 1] + 1;
            }
            call.en_sp = call.en_sp - 1;
            ops.expect_operand = 0;
            // An enum construction is the value's root: tag the pending composite type with the
            // enum, so a `let e = E::A(x)` binding is enum-typed for a following `match e`.
            stmt.pending_ctuple = 0;
            stmt.pending_cstruct = 0;
            stmt.pending_carray = 0;
            stmt.pending_carray_struct = 0;
            stmt.pending_cenum = call.en_ename[call.en_sp] + 1;
            Node::EnumInit() as Word + (call.en_bytesize[call.en_sp] * 1024 + call.en_count[call.en_sp]) * 64
        } else {
        if top == OpCode::TupleMark() as Word {
            // A `)` closing a tuple construction: pop the mark, count the last element (when a
            // value was parsed), and emit the TupleInit packing `byte_size * 1024 + count` with
            // byte_size = count * 8 (Word-sized elements) -- the ArrayLit shape reconstruct
            // consumes.
            ops.opsp = ops.opsp - 1;
            ops.closing = 0;
            if ops.expect_operand == 0 {
                call.tp_count[call.tp_sp - 1] = call.tp_count[call.tp_sp - 1] + 1;
            }
            call.tp_sp = call.tp_sp - 1;
            ops.expect_operand = 0;
            // Record this tuple as the value's current root composite (all-Word elements), so a
            // `let` binding to it can arm `t.N` access; a later operator/call clears it.
            stmt.pending_ctuple = call.tp_count[call.tp_sp];
            stmt.pending_cstruct = 0;
            stmt.pending_carray = 0;
            stmt.pending_carray_struct = 0;
            stmt.pending_cenum = 0;
            Node::TupleInit() as Word + (call.tp_count[call.tp_sp] * 8 * 1024 + call.tp_count[call.tp_sp]) * 64
        } else {
            ops.opsp = ops.opsp - 1;
            emit_op(top)
        } } } }
    } else {
        ops.closing = 0;
        0
    }
}

// A `,`: flush the current call argument's operators down to the call marker, then count
// the argument.
fn step_cdraining() -> Word {
    if ops.opsp > 0 andalso ops.opstack[ops.opsp - 1] != OpCode::CallMark() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::StructMark() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::ArrayMark() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::EnumMark() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::Paren() as Word andalso ops.opstack[ops.opsp - 1] != OpCode::TupleMark() as Word {
        ops.opsp = ops.opsp - 1;
        let op = ops.opstack[ops.opsp];
        emit_op(op)
    } else {
        call.cdraining = 0;
        if ops.opstack[ops.opsp - 1] == OpCode::Paren() as Word {
            // The first top-level `,` inside a `(...)` proves it a tuple, not grouping: promote
            // the Paren marker to a TupleMark and seed the element count at one (the element just
            // drained). The `)` closes it into a TupleInit.
            ops.opstack[ops.opsp - 1] = OpCode::TupleMark() as Word;
            call.tp_count[call.tp_sp] = 1;
            call.tp_sp = call.tp_sp + 1;
            ops.expect_operand = 1;
            0
        } else {
        if ops.opstack[ops.opsp - 1] == OpCode::TupleMark() as Word {
            // A `,` between later tuple elements: count the element just drained.
            call.tp_count[call.tp_sp - 1] = call.tp_count[call.tp_sp - 1] + 1;
            ops.expect_operand = 1;
            0
        } else {
        if ops.opstack[ops.opsp - 1] == OpCode::StructMark() as Word {
            // A `,` between struct-construction fields: count the field just drained and
            // await the next field name.
            structdefs.sc_count[structdefs.sc_sp - 1] = structdefs.sc_count[structdefs.sc_sp - 1] + 1;
            structdefs.sc_phase = 2;
            ops.expect_operand = 0;
            0
        } else {
        if ops.opstack[ops.opsp - 1] == OpCode::ArrayMark() as Word {
            // A `,` between array-literal elements: count the element just drained.
            call.al_count[call.al_sp - 1] = call.al_count[call.al_sp - 1] + 1;
            ops.expect_operand = 1;
            0
        } else {
        if ops.opstack[ops.opsp - 1] == OpCode::EnumMark() as Word {
            // A `,` between enum-payload elements: count the payload element just drained.
            call.en_count[call.en_sp - 1] = call.en_count[call.en_sp - 1] + 1;
            ops.expect_operand = 1;
            0
        } else {
            call.call_count[call.call_sp - 1] = call.call_count[call.call_sp - 1] + 1;
            ops.expect_operand = 1;
            0
        } } } } }
    }
}

// A `}` closing a struct construction: flush the operators above the StructMark, then pop
// the mark, count the last field (when a value was parsed), and emit a StructInit node
// packing the struct's flat byte size (summed per field at its declaration) and the field
// count as `byte_size * 1024 + count`. The field-expression nodes precede it in postorder,
// exactly as a Call's arguments precede the Call. The reconstruct stage reads the byte size
// directly, so a mixed-scalar struct (a `Byte` beside a `Word`) is sized correctly.
fn step_sc_closing() -> Word {
    if ops.opsp > 0 andalso ops.opstack[ops.opsp - 1] != OpCode::StructMark() as Word {
        ops.opsp = ops.opsp - 1;
        let op = ops.opstack[ops.opsp];
        emit_op(op)
    } else {
        ops.opsp = ops.opsp - 1;
        structdefs.sc_closing = 0;
        if ops.expect_operand == 0 {
            structdefs.sc_count[structdefs.sc_sp - 1] = structdefs.sc_count[structdefs.sc_sp - 1] + 1;
        }
        structdefs.sc_sp = structdefs.sc_sp - 1;
        ops.expect_operand = 0;
        // Record this struct as the value's current root composite, so a `let` binding to it can
        // arm `x.field` access; a later operator/call clears it.
        stmt.pending_ctuple = 0;
        stmt.pending_cstruct = structdefs.sc_name[structdefs.sc_sp] + 1;
        stmt.pending_carray = 0;
        stmt.pending_carray_struct = 0;
        stmt.pending_cenum = 0;
        Node::StructInit() as Word + (structdefs.sd_bytesize[structdefs.sc_name[structdefs.sc_sp]] * 1024 + structdefs.sc_count[structdefs.sc_sp]) * 64
    }
}

// An operator or statement token.
fn step_op(k: Word) -> Word {
    if k == Tok::For() as Word {
        // Push a fresh loop context; a nested loop stacks above the enclosing one.
        forst.for_phase[forst.for_sp] = 1;
        forst.for_sp = forst.for_sp + 1;
        0
    } else {
    if k == Tok::Let() as Word {
        stmt.let_phase = 1;
        0
    } else {
    if k == Tok::Break() as Word {
        // A `break;` statement: record a Break node (kind 29) carrying the enclosing
        // `for .. limit` loop's outcome slot (for_oc), which codegen sets to the user-break
        // outcome code before the Break op. The terminating `;` is consumed as a no-op.
        stmt.stmt_kind[stmt.stmt_count] = Node::Break() as Word;
        stmt.stmt_arg[stmt.stmt_count] = forst.for_oc[forst.for_sp - 1];
        stmt.stmt_count = stmt.stmt_count + 1;
        stmt.break_pending = 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Semi() as Word {
        if stmt.break_pending == 1 {
            // The `;` after a `break` was already recorded; consume it without draining.
            stmt.break_pending = 0;
        } else {
            ops.drain_reason = 0;
            ops.draining = 1;
        }
        0
    } else {
    if k == Tok::Yield() as Word {
        // `yield` is a loosest-binding prefix: push its marker (precedence 0) so no
        // operator pops across it and the whole following expression becomes its operand.
        ops.opstack[ops.opsp] = OpCode::YieldMark() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Match() as Word {
        // `match` opens a scrutinee-then-arms context; its scrutinee is an operand.
        mat.match_phase[mat.match_sp] = 1;
        mat.match_argcount[mat.match_sp] = 0;
        mat.match_isenum[mat.match_sp] = 0;
        mat.match_haswc[mat.match_sp] = 0;
        mat.match_sp = mat.match_sp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Not() as Word {
        ops.opstack[ops.opsp] = OpCode::Not() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Minus() as Word andalso ops.expect_operand == 1 {
        ops.opstack[ops.opsp] = OpCode::Neg() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        0
    } else {
        let op = opcode_of(k);
        if op > 0 {
            ops.pending_op = op;
            ops.pending_prec = prec_of(op);
            ops.resolving = 1;
            ops.expect_operand = 1;
            0
        } else {
            0
        }
    } } } } } } } }
}

// The conditional tokens `{`, `}`, `if`, `else`. A `{` after a condition drains it
// (reason 2) then enters the then branch; a `{` after `else` enters the else branch; a
// `}` drains a branch (reason 3 then, 4 else) or, with no pending conditional, the body
// (reason 1); `if` pushes a context and `else` advances one. A block closing while an
// operand is still expected has no tail, so its Unit value is emitted for the fold.
fn step_if(k: Word) -> Word {
    if k == Tok::If() as Word {
        branch.if_phase[branch.if_sp] = 1;
        branch.if_sp = branch.if_sp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::Else() as Word {
        branch.if_phase[branch.if_sp - 1] = 4;
        0
    } else {
    if k == Tok::LBrace() as Word {
        if branch.if_sp > 0 {
            if branch.if_phase[branch.if_sp - 1] == 1 {
                ops.drain_reason = 2;
                ops.draining = 1;
            } else {
                branch.if_phase[branch.if_sp - 1] = 5;
                branch.if_stmt_start[branch.if_sp - 1] = stmt.stmt_count;
                branch.if_opbase[branch.if_sp - 1] = ops.opsp;
                branch.if_seq[branch.if_sp - 1] = stmt.open_seq;
                stmt.open_seq = stmt.open_seq + 1;
                stmt.pbase[stmt.pbase_sp] = stmt.stmt_base;
                stmt.pbase_sp = stmt.pbase_sp + 1;
                stmt.stmt_base = stmt.pstmt_sp;
                ops.expect_operand = 1;
            }
        }
        0
    } else {
        // Close the innermost open block. A pending if-branch and an active for body can
        // both want this `}`; the one opened most recently (the larger `open_seq` stamp)
        // is the inner one, so a `for` written inside an `if` branch closes as a for body
        // (reason 7) rather than being mistaken for the branch's `}` (reason 3 or 4).
        let if_open = branch.if_sp > 0;
        let for_open = forst.for_sp > 0 andalso forst.for_phase[forst.for_sp - 1] == 7;
        let if_seq = if if_open { branch.if_seq[branch.if_sp - 1] } else { 0 };
        let for_seq = if for_open { forst.for_seq[forst.for_sp - 1] } else { 0 };
        let close_for = for_open andalso (not if_open orelse for_seq > if_seq);
        if close_for {
            ops.drain_reason = 7;
        } else {
            if if_open {
                if branch.if_phase[branch.if_sp - 1] == 2 {
                    ops.drain_reason = 3;
                } else {
                    ops.drain_reason = 4;
                }
            } else {
                ops.drain_reason = 1;
            }
        }
        ops.draining = 1;
        if ops.expect_operand == 1 {
            ops.expect_operand = 0;
            Node::Unit() as Word
        } else {
            0
        }
    } } }
}

// The `if` without `else`: when the then branch has folded (phase 3) and no `else`
// follows, synthesize an empty else block whose Unit tail the fold wraps into the If, and
// push the triggering token back for reprocessing.
fn synth_empty_else() -> Word {
    ps.cursor = ps.cursor - 1;
    branch.if_phase[branch.if_sp - 1] = 5;
    branch.if_stmt_start[branch.if_sp - 1] = stmt.stmt_count;
    branch.if_opbase[branch.if_sp - 1] = ops.opsp;
    branch.if_seq[branch.if_sp - 1] = stmt.open_seq;
    stmt.open_seq = stmt.open_seq + 1;
    stmt.pbase[stmt.pbase_sp] = stmt.stmt_base;
    stmt.pbase_sp = stmt.pbase_sp + 1;
    stmt.stmt_base = stmt.pstmt_sp;
    ops.drain_reason = 4;
    ops.draining = 1;
    ops.expect_operand = 0;
    Node::Unit() as Word
}

// A token that starts a statement (so a completed block-form operand before it was a
// statement, not the block tail).
fn is_stmt_start(k: Word) -> Word {
    if k == Tok::Ident() as Word orelse k == Tok::IntLit() as Word orelse k == Tok::If() as Word orelse k == Tok::Let() as Word orelse k == Tok::Yield() as Word orelse k == Tok::For() as Word orelse k == Tok::Match() as Word {
        1
    } else {
        0
    }
}

// The `match` structural tokens. Phase 1 awaits the scrutinee's `{` (drain reason 8, which
// reserves the scrutinee temp slot and moves to the arm patterns); phase 2 reads an arm
// pattern (an integer literal emitted as a Literal node and counted, a `_` wildcard, or
// `}` ending the arms); phase 3 awaits `=>`; phase 4 reads the arm result, ended by a
// match-level `,` (reason 9, next arm) or the closing `}` (reason 10, build).
fn step_match(k: Word, v: Word) -> Word {
    let sp = mat.match_sp - 1;
    let mp = mat.match_phase[sp];
    if mp == 1 {
        ops.drain_reason = 8;
        ops.draining = 1;
        0
    } else {
    if mp == 2 {
        if k == Tok::IntLit() as Word {
            mat.match_argcount[sp] = mat.match_argcount[sp] + 1;
            mat.match_phase[sp] = 3;
            Node::Literal() as Word + v * 64
        } else {
        if k == Tok::Underscore() as Word {
            mat.match_phase[sp] = 3;
            // A `_` wildcard arm: its result becomes the enum match's catch-all (no IsEnum test).
            mat.match_haswc[sp] = 1;
            0
        } else {
        if k == Tok::Ident() as Word {
            // A unit enum-variant pattern `Name::Variant()` folds to the variant's
            // discriminant literal, the same arm an integer literal forms. Recognise the
            // enum name, then read the `::Variant()` in step_mpat.
            ps.found_flag = 0;
            for i in 0..enums.enum_count limit 256 {
                if enums.edata[i] == v {
                    ps.found_flag = 1;
                }
            }
            if ps.found_flag == 1 {
                mat.enum_name = v;
                mat.mpat_phase = 1;
            }
            0
        } else {
            mat.match_build = 1;
            0
        } } }
    } else {
    if mp == 3 {
        if k == Tok::FatArrow() as Word {
            mat.match_phase[sp] = 4;
            ops.expect_operand = 1;
        }
        0
    } else {
        if k == Tok::Comma() as Word {
            ops.drain_reason = 9;
            ops.draining = 1;
            0
        } else {
            ops.drain_reason = 10;
            ops.draining = 1;
            0
        }
    } } }
}

// Emit the match build record (kind 34): its arg packs the scrutinee temp slot and the
// literal-arm count as `temp * 1024 + count`. The match is now a completed block-form
// operand, so blockform marks it and expect_operand clears.
fn step_match_build() -> Word {
    mat.match_build = 0;
    let sp = mat.match_sp - 1;
    let temp = mat.match_temp[sp];
    let ac = mat.match_argcount[sp];
    mat.match_sp = sp;
    ops.expect_operand = 0;
    stmt.blockform = 1;
    if mat.match_isenum[sp] == 1 {
        // An enum-value match: emit the EnumMatchBuild signal packing temp, arm count, the
        // wildcard flag, and the enum name id. reconstruct assembles the IsEnum-loop parts and
        // emits an EnumMatch node.
        Node::EnumMatchBuild() as Word + (temp + ac * 1024 + mat.match_haswc[sp] * 1048576 + mat.match_ename[sp] * 2097152) * 64
    } else {
        Node::MatchBuild() as Word + (temp * 1024 + ac) * 64
    }
}

// The `for` loop header: phase 1 the variable name, 2 the `in`, 3 the low bound (drained
// at `..`, reason 5), 4 the high bound (drained at the contextual `limit` identifier,
// reason 6), 5 the literal cap, 6 the opening `{` (which binds the loop variable and marks
// the body, phase 7). The bounds are ordinary expressions handled by step_normal.
fn step_forheader(k: Word, v: Word) -> Word {
    let fp = forst.for_sp - 1;
    if forst.for_phase[fp] == 1 {
        if k == Tok::Ident() as Word {
            forst.for_var[fp] = v;
            forst.for_phase[fp] = 2;
        }
        0
    } else {
    if forst.for_phase[fp] == 2 {
        if k == Tok::In() as Word {
            forst.for_phase[fp] = 3;
            ops.expect_operand = 1;
        }
        0
    } else {
    if forst.for_phase[fp] == 3 {
        if k == Tok::DotDot() as Word {
            ops.drain_reason = 5;
            ops.draining = 1;
            0
        } else {
            step_normal(k, v)
        }
    } else {
    if forst.for_phase[fp] == 4 {
        if k == Tok::Ident() as Word andalso v == toks.limit_id {
            ops.drain_reason = 6;
            ops.draining = 1;
            0
        } else {
            step_normal(k, v)
        }
    } else {
    if forst.for_phase[fp] == 5 {
        if k == Tok::IntLit() as Word {
            forst.for_cap[fp] = v;
            forst.for_phase[fp] = 6;
        }
        0
    } else {
        if k == Tok::LBrace() as Word {
            stmt.let_names[stmt.let_count] = forst.for_var[fp];
            stmt.scope_slot[stmt.let_count] = forst.for_vslot[fp];
            stmt.let_count = stmt.let_count + 1;
            forst.for_phase[fp] = 7;
            forst.for_stmt_start[fp] = stmt.stmt_count;
            forst.for_seq[fp] = stmt.open_seq;
            stmt.open_seq = stmt.open_seq + 1;
            stmt.pbase[stmt.pbase_sp] = stmt.stmt_base;
            stmt.pbase_sp = stmt.pbase_sp + 1;
            stmt.stmt_base = stmt.pstmt_sp;
            ops.expect_operand = 1;
        }
        0
    } } } } }
}

// After the body drains, emit the ForLimit's parts, one per iteration: the four literal
// nodes (cap, 0, 1, 2), then the five loop slots (a SlotRecord each), then a ForBuild
// signal; finally the ForLimit statement (arg = its 12-word limit_parts entry start) is
// recorded for the enclosing block fold.
fn step_for_emit() -> Word {
    let fp = forst.for_sp - 1;
    if forst.for_emit_i == 0 {
        forst.for_emit_i = 1;
        Node::Literal() as Word + forst.for_cap[fp] * 64
    } else {
    if forst.for_emit_i == 1 {
        forst.for_emit_i = 2;
        Node::Literal() as Word
    } else {
    if forst.for_emit_i == 2 {
        forst.for_emit_i = 3;
        Node::Literal() as Word + 1 * 64
    } else {
    if forst.for_emit_i == 3 {
        forst.for_emit_i = 4;
        Node::Literal() as Word + 2 * 64
    } else {
    if forst.for_emit_i == 4 {
        forst.for_emit_i = 5;
        Node::SlotRecord() as Word + forst.for_vslot[fp] * 64
    } else {
    if forst.for_emit_i == 5 {
        forst.for_emit_i = 6;
        Node::SlotRecord() as Word + forst.for_end_slot[fp] * 64
    } else {
    if forst.for_emit_i == 6 {
        forst.for_emit_i = 7;
        Node::SlotRecord() as Word + forst.for_ctr[fp] * 64
    } else {
    if forst.for_emit_i == 7 {
        forst.for_emit_i = 8;
        Node::SlotRecord() as Word + forst.for_cap_slot[fp] * 64
    } else {
    if forst.for_emit_i == 8 {
        forst.for_emit_i = 9;
        Node::SlotRecord() as Word + forst.for_oc[fp] * 64
    } else {
    if forst.for_emit_i == 9 {
        forst.for_emit_i = 10;
        Node::ForBuild() as Word
    } else {
        // The loop's parts are emitted; record its ForLimit statement, pop the loop
        // context, and let the enclosing block fold it in.
        stmt.stmt_kind[stmt.stmt_count] = Node::ForLimit() as Word;
        stmt.stmt_arg[stmt.stmt_count] = 12 * forst.forlimit_count;
        stmt.stmt_count = stmt.stmt_count + 1;
        forst.forlimit_count = forst.forlimit_count + 1;
        forst.for_emit = 0;
        forst.for_sp = forst.for_sp - 1;
        ops.expect_operand = 1;
        0
    } } } } } } } } } }
}

// The expression-position token dispatch: the conditional tokens route to step_if.
fn step_normal(k: Word, v: Word) -> Word {
    if k == Tok::LBrace() as Word orelse k == Tok::RBrace() as Word orelse k == Tok::If() as Word orelse k == Tok::Else() as Word {
        step_if(k)
    } else {
    if k == Tok::IntLit() as Word {
        ops.expect_operand = 0;
        Node::Literal() as Word + v * 64
    } else {
    if k == Tok::Str() as Word {
        // A string literal: emit a StrLit carrying the intern id (v), which codegen interns as a
        // StaticStr pool entry.
        ops.expect_operand = 0;
        Node::StrLit() as Word + v * 64
    } else {
    if k == Tok::Ident() as Word {
        step_ident(v)
    } else {
    if k == Tok::LParen() as Word {
        ops.opstack[ops.opsp] = OpCode::Paren() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::LBracket() as Word {
        // A `[` in operand position opens an array literal (a `[` after an operand is an index,
        // intercepted earlier). Push an ArrayMark that blocks precedence across the elements.
        call.al_count[call.al_sp] = 0;
        call.al_sp = call.al_sp + 1;
        ops.opstack[ops.opsp] = OpCode::ArrayMark() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        0
    } else {
    if k == Tok::RParen() as Word {
        ops.closing = 1;
        0
    } else {
    if k == Tok::RBracket() as Word {
        da.iclosing = 1;
        0
    } else {
    if k == Tok::Comma() as Word {
        call.cdraining = 1;
        0
    } else {
        step_op(k)
    } } } } } } } } }
}

// The struct-field-access postfix (ps.fa_phase 1/2), after a struct-typed parameter Local was
// emitted. Phase 1 awaits an optional `.` (a non-`.` token is pushed back, the parameter was
// used whole); phase 2 reads the field name, resolves its flat byte offset and ScalarKind in
// the parameter's struct, and emits a FieldAccess (kind 28) that pops the parameter Local,
// packing the GetField operand as offset + kind * 65536. Held in its own function so the
// dispatch chain is not deepened (the parser's own conditional stack is bounded).
fn step_fieldaccess(k: Word, v: Word) -> Word {
    if ps.fa_phase == 1 {
        if k == Tok::Dot() as Word {
            ps.fa_phase = 2;
        } else {
            ps.fa_phase = 0;
            ps.cursor = ps.cursor - 1;
        }
        0
    } else {
    if ps.fa_phase == 2 {
        // The field name: resolve its flat offset, ScalarKind (element kind for an array), and
        // total byte size, and DEFER emission to phase 3, where the following token decides a
        // scalar read (`p.f`) from an array-element read (`p.xs[i]`).
        if k == Tok::Ident() as Word {
            structdefs.sc_fieldpos = structdefs.sd_fstart[ps.fa_struct];
            for i in 0..structdefs.sd_fcount[ps.fa_struct] limit 64 {
                if structdefs.sd_fname[structdefs.sd_fstart[ps.fa_struct] + i] == v {
                    structdefs.sc_fieldpos = structdefs.sd_fstart[ps.fa_struct] + i;
                }
            }
            ps.fa_off = structdefs.sd_foffset[structdefs.sc_fieldpos];
            ps.fa_kind = structdefs.sd_fkind[structdefs.sc_fieldpos];
            ps.fa_size = structdefs.sd_fsize[structdefs.sc_fieldpos];
            ps.fa_fstruct = structdefs.sd_fstruct[structdefs.sc_fieldpos];
            ps.fa_ftuple = structdefs.sd_ftuple[structdefs.sc_fieldpos];
            ps.fa_phase = 3;
        } else {
            ps.fa_phase = 0;
        }
        0
    } else {
        // Phase 3: a `[` is an array-element read, a `.` a nested struct field read, anything
        // else the scalar read.
        if k == Tok::LBracket() as Word {
            // Array element `p.xs[i]`: emit the FlatNested field read (the whole array value,
            // packed offset + size*65536 + Array-variant(1)*2^32), open the index (an
            // IndexMark blocks precedence), and mark the closing `]` to emit the element read. A
            // STRUCT-element array field (`fa_fstruct > 0`, e.g. `h.ps[i]`) marks the `]` to emit a
            // GetIndex(FlatNested{element-struct size, Struct}) and arm `.field` access into the
            // element (the `fa_index_nested` path); a scalar-element array field emits a scalar
            // ArrIndex of the element kind.
            ps.fa_phase = 0;
            if ps.fa_fstruct > 0 {
                da.fa_index = 1;
                da.fa_index_nested = 1;
                da.fa_index_size = structdefs.sd_bytesize[ps.fa_fstruct - 1];
                da.fa_index_struct = ps.fa_fstruct - 1;
            } else {
                da.fa_index = 1;
                da.fa_index_kind = ps.fa_kind;
            }
            ops.opstack[ops.opsp] = OpCode::IndexMark() as Word;
            ops.opsp = ops.opsp + 1;
            ops.expect_operand = 1;
            Node::FieldAccessNested() as Word + (ps.fa_off + ps.fa_size * 65536 + 4294967296) * 64
        } else {
        if k == Tok::Dot() as Word {
            if ps.fa_ftuple > 0 {
                // Nested tuple field `s.p.N`: emit the FlatNested read of the tuple field (the
                // whole tuple value, Tuple-variant 0), then hand off to the tuple-index postfix
                // (ta_phase 2) to read `.N` and emit the GetTupleField of element N.
                ps.fa_phase = 0;
                ps.ta_phase = 2;
                ps.ta_tuple = ps.fa_ftuple - 1;
                Node::FieldAccessNested() as Word + (ps.fa_off + ps.fa_size * 65536) * 64
            } else {
                // Nested struct field `p.inner.x`: emit the FlatNested field read of `inner` (the
                // whole nested struct value, Struct-variant 2), then re-enter field-access mode with
                // the inner struct as the base so the following field name resolves into it.
                ps.fa_struct = ps.fa_fstruct - 1;
                ps.fa_phase = 2;
                Node::FieldAccessNested() as Word + (ps.fa_off + ps.fa_size * 65536 + 2 * 4294967296) * 64
            }
        } else {
            // Scalar read `p.f`: emit the flat GetField and push the token back for the normal
            // dispatch (as the pre-array path did directly at the field name).
            ps.fa_phase = 0;
            ps.cursor = ps.cursor - 1;
            ops.expect_operand = 0;
            Node::FieldAccess() as Word + (ps.fa_off + ps.fa_kind * 65536) * 64
        } }
    } }
}

// The tuple-field-access postfix (ps.ta_phase 1/2), after a tuple-typed parameter Local was
// emitted. Phase 1 awaits an optional `.` (a non-`.` token is pushed back, the parameter was used
// whole); phase 2 reads the element index N (an integer literal), resolves element N's flat byte
// offset and ScalarKind from the parameter's tuple layout, and emits a TupleField (kind 37) that
// pops the parameter Local, packing the GetTupleField operand as offset + kind * 65536. Held in
// its own function so the dispatch chain is not deepened.
fn step_tupleaccess(k: Word, v: Word) -> Word {
    if ps.ta_phase == 1 {
        if k == Tok::Dot() as Word {
            ps.ta_phase = 2;
        } else {
            ps.ta_phase = 0;
            ps.cursor = ps.cursor - 1;
        }
        0
    } else {
        if k == Tok::IntLit() as Word {
            let base = tupledefs.tup_estart[ps.ta_tuple];
            ps.fa_off = tupledefs.tup_eoffset[base + v];
            ps.fa_kind = tupledefs.tup_ekind[base + v];
            ps.ta_phase = 0;
            ops.expect_operand = 0;
            Node::TupleField() as Word + (ps.fa_off + ps.fa_kind * 65536) * 64
        } else {
            ps.ta_phase = 0;
            0
        }
    }
}

// The array-access postfix (ps.aa_phase 1), after a let-bound array Local was emitted. A `[` opens
// the element index (an IndexMark blocks precedence, `da.fa_index` marks the closing `]` to emit
// the ArrIndex/GetIndex of the element kind); the array value is the already-emitted Local, so no
// FlatNested extraction is needed (unlike a struct array FIELD `p.xs[i]`). A non-`[` token is
// pushed back (the array was used whole).
fn step_arrayaccess(k: Word, v: Word) -> Word {
    if k == Tok::LBracket() as Word {
        ps.aa_phase = 0;
        da.fa_index = 1;
        da.fa_index_kind = ps.aa_kind;
        ops.opstack[ops.opsp] = OpCode::IndexMark() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        v * 0
    } else {
        ps.aa_phase = 0;
        ps.cursor = ps.cursor - 1;
        0
    }
}

// The struct-array-access postfix (ps.sa_phase 1), after an array-of-struct parameter Local was
// emitted. A `[` opens the element index and marks the closing `]` to emit an ArrIndexNested
// (GetIndex(FlatNested{size, Struct})), recording the element struct's byte size and declaration
// index so the `]` can arm the field-access postfix for a following `.field`. A non-`[` token is
// pushed back (the parameter was used whole).
fn step_structarrayaccess(k: Word, v: Word) -> Word {
    if k == Tok::LBracket() as Word {
        ps.sa_phase = 0;
        da.fa_index = 1;
        da.fa_index_nested = 1;
        da.fa_index_size = ps.sa_size;
        da.fa_index_struct = ps.sa_struct;
        ops.opstack[ops.opsp] = OpCode::IndexMark() as Word;
        ops.opsp = ops.opsp + 1;
        ops.expect_operand = 1;
        v * 0
    } else {
        ps.sa_phase = 0;
        ps.cursor = ps.cursor - 1;
        0
    }
}

// The normal parse-phase dispatch: a `let` binding's name or `=`, else an expression
// token.
fn step_dispatch_normal(k: Word, v: Word) -> Word {
    if structdefs.sc_phase == 1 {
        // A struct name was read; the `{` opens its field list. Push the struct context and
        // a StructMark that blocks precedence across the fields, then await a field name.
        if k == Tok::LBrace() as Word {
            structdefs.sc_name[structdefs.sc_sp] = structdefs.sc_pending;
            structdefs.sc_count[structdefs.sc_sp] = 0;
            structdefs.sc_sp = structdefs.sc_sp + 1;
            ops.opstack[ops.opsp] = OpCode::StructMark() as Word;
            ops.opsp = ops.opsp + 1;
            structdefs.sc_phase = 2;
            ops.expect_operand = 0;
        }
        0
    } else {
    if structdefs.sc_phase == 2 {
        // A construction field name: resolve its declaration POSITION within the struct being
        // constructed (the top construction context) and emit a FieldPos marker so reconstruct
        // can place this field's value at its declaration slot even when written out of order.
        // The `:` follows.
        if k == Tok::Ident() as Word {
            structdefs.sc_phase = 3;
            structdefs.sc_fieldpos = 0;
            for i in 0..structdefs.sd_fcount[structdefs.sc_name[structdefs.sc_sp - 1]] limit 64 {
                if structdefs.sd_fname[structdefs.sd_fstart[structdefs.sc_name[structdefs.sc_sp - 1]] + i] == v {
                    structdefs.sc_fieldpos = i;
                }
            }
            Node::FieldPos() as Word + structdefs.sc_fieldpos * 64
        } else {
            0
        }
    } else {
    if structdefs.sc_phase == 3 {
        // The `:` before a field's value expression.
        if k == Tok::Colon() as Word {
            structdefs.sc_phase = 0;
            ops.expect_operand = 1;
        }
        0
    } else {
    if structdefs.sc_sp > 0 andalso structdefs.sc_phase == 0 andalso k == Tok::RBrace() as Word {
        // Inside a construction with a field value parsed, the `}` closes it (a block `}`
        // has `sc_sp == 0`). Drain the last field to the StructMark and emit the StructInit.
        structdefs.sc_closing = 1;
        0
    } else {
    if stmt.let_phase == 2 {
        if k == Tok::Eq() as Word {
            stmt.let_phase = 0;
            stmt.pstmt_kind[stmt.pstmt_sp] = 0;
            stmt.pstmt_name[stmt.pstmt_sp] = stmt.pending_let_name;
            stmt.pstmt_sp = stmt.pstmt_sp + 1;
            ops.expect_operand = 1;
            // Begin tracking this `let` value's root composite type fresh.
            stmt.pending_ctuple = 0;
            stmt.pending_cstruct = 0;
            stmt.pending_carray = 0;
            stmt.pending_carray_struct = 0;
            stmt.pending_cenum = 0;
        }
        0
    } else {
    if stmt.let_phase == 1 {
        if k == Tok::Ident() as Word {
            stmt.pending_let_name = v;
            stmt.let_phase = 2;
        }
        0
    } else {
    if da.cda_phase == 1 {
        if k == Tok::Dot() as Word {
            da.cda_phase = 2;
        }
        0
    } else {
    if da.cda_phase == 2 {
        step_cfield(k, v)
    } else {
    if da.da_phase == 1 {
        if k == Tok::Dot() as Word {
            da.da_phase = 2;
        }
        0
    } else {
    if da.da_phase == 2 {
        step_dafield(k, v)
    } else {
    if da.da_phase == 3 {
        step_daindex(k)
    } else {
    if call.call_phase == 1 {
        // A call name was read; the `(` opens the argument list.
        if k == Tok::LParen() as Word {
            call.call_chunk[call.call_sp] = call.call_pending;
            call.call_count[call.call_sp] = 0;
            call.call_sp = call.call_sp + 1;
            ops.opstack[ops.opsp] = OpCode::CallMark() as Word;
            ops.opsp = ops.opsp + 1;
            call.call_phase = 0;
            ops.expect_operand = 1;
        }
        0
    } else {
    if mat.enum_phase >= 1 {
        // An open `Name::Variant() as Word` enum cast consumes its remaining tokens.
        step_enum(k, v)
    } else {
    if da.as_skip == 1 {
        // The target type name after a plain `as` cast; skip it. The Cast node was
        // already emitted when the `as` token was seen.
        da.as_skip = 0;
        0
    } else {
    if k == Tok::As() as Word {
        // A plain `<expr> as Type` cast (not an enum cast, which step_enum consumes):
        // the operand is on the host stack, so emit a Cast node (kind 26) wrapping it and
        // arm the skip of the target type name. The stages only cast `Byte as Word`, which
        // codegen lowers to a single ByteToWord op.
        da.as_skip = 1;
        ops.expect_operand = 0;
        Node::Cast() as Word
    } else {
    if forst.for_sp > 0 andalso forst.for_phase[forst.for_sp - 1] >= 1 andalso forst.for_phase[forst.for_sp - 1] <= 6 {
        step_forheader(k, v)
    } else {
        step_normal(k, v)
    } } } } } } } } } } } } } } } }
}

// Dispatch a body token: the else-less `if` synthesis and the block-form-statement commit
// come first, then the normal phase dispatch.
fn step_body_dispatch(k: Word, v: Word) -> Word {
    if ps.in_guard == 1 andalso k == Tok::LBrace() as Word andalso da.post_index == 0 andalso da.da_phase == 0 {
        // The body's opening `{` ends the guard expression: drain it (reason 11), then
        // step_draining emits the guard's Done and arms the real body. A pending
        // data-field read (post_index or da_phase active) must flush first, so the
        // guard's trailing `d.f` read lands before the boundary, exactly as a match
        // boundary defers to a pending read.
        ops.drain_reason = 11;
        ops.draining = 1;
        0
    } else {
    if branch.if_sp > 0 andalso branch.if_phase[branch.if_sp - 1] == 3 andalso k != Tok::Else() as Word {
        synth_empty_else()
    } else {
        if stmt.blockform == 1 {
            stmt.blockform = 0;
            if is_stmt_start(k) == 1 {
                stmt.stmt_kind[stmt.stmt_count] = Node::ExprStmt() as Word;
                stmt.stmt_arg[stmt.stmt_count] = 0;
                stmt.stmt_count = stmt.stmt_count + 1;
                ops.expect_operand = 1;
            }
        }
        if da.post_index == 1 {
            // The token after a `]` decides read versus indexed assignment.
            step_post_index(k)
        } else {
        if mat.mpat_phase >= 1 {
            // An open enum-variant match pattern (`Name::Variant()`) consumes its tokens.
            step_mpat(k, v)
        } else {
        if mat.match_sp > 0 andalso da.da_phase == 0 {
            // Route the match structural tokens (a pattern, `=>`, the scrutinee's `{`, the
            // arms' `}`, or a match-level `,`) to step_match; the scrutinee and arm results
            // dispatch normally. A pending data-field read (da_phase nonzero) must flush
            // first, so the scrutinee or arm-result DataRead lands before the match drain;
            // step_daindex emits it and pushes the boundary token back for reinterpretation.
            let mp = mat.match_phase[mat.match_sp - 1];
            if mp == 2 orelse mp == 3 orelse (mp == 1 andalso k == Tok::LBrace() as Word) orelse (mp == 4 andalso k == Tok::RBrace() as Word) orelse (mp == 4 andalso k == Tok::Comma() as Word) {
                step_match(k, v)
            } else {
                step_dispatch_normal(k, v)
            }
        } else {
            step_dispatch_normal(k, v)
        } } }
    } }
}

// Flush the expression's operators; emptied, commit a statement (`;`), fold the block
// (`}`), enter the then branch (a drained condition), or fold a branch (its `}`).
fn step_draining() -> Word {
    // A grouping marker (Paren, IndexMark, CallMark) delimits an enclosing context and
    // is consumed by its own bracket handler, never by a sub-expression drain, so
    // draining stops at it rather than emitting it as a spurious operator. The
    // YieldMark is the exception: at a statement (reason 0) or block-tail (reason 1)
    // drain the whole yield expression is complete, so the marker is drained there as
    // the YieldExpr; at any inner boundary (an if condition, a match scrutinee, an arm
    // result) it, too, blocks so the yield spans the whole following expression.
    let has_op = ops.opsp > 0;
    let top = if has_op { ops.opstack[ops.opsp - 1] } else { 0 };
    let marker = top == OpCode::Paren() as Word
        orelse top == OpCode::IndexMark() as Word
        orelse top == OpCode::CallMark() as Word;
    // A YieldMark completes (drains as its YieldExpr) at a statement (reason 0) or the
    // body tail (reason 1), and also at an if-branch fold (reason 3 or 4) when the
    // `yield` was written inside that branch. The latter is true when the YieldMark
    // sits above the operator-stack depth captured at the branch's open: a `yield`
    // pushed inside the branch raises `opsp` past `if_opbase`, while a `yield`
    // wrapping the whole conditional was pushed before the branch opened and so is at
    // or below the base, where it must keep blocking so the built If becomes its operand.
    let base = if branch.if_sp > 0 {
        branch.if_opbase[branch.if_sp - 1]
    } else {
        0
    };
    let is_branch_fold = ops.drain_reason == 3 orelse ops.drain_reason == 4;
    let branch_tail = is_branch_fold andalso ops.opsp > base;
    let yield_completes = ops.drain_reason == 0
        orelse ops.drain_reason == 1
        orelse branch_tail;
    let yield_blocks = top == OpCode::YieldMark() as Word andalso not yield_completes;
    if has_op andalso not marker andalso not yield_blocks {
        ops.opsp = ops.opsp - 1;
        let op = ops.opstack[ops.opsp];
        emit_op(op)
    } else {
        if ops.drain_reason == 0 {
            if stmt.pstmt_sp > stmt.stmt_base {
                stmt.pstmt_sp = stmt.pstmt_sp - 1;
                if stmt.pstmt_kind[stmt.pstmt_sp] == 0 {
                    // A `let`: claim the next frame slot and bind its name.
                    let slot = ps.pcount + stmt.slot_count;
                    stmt.slot_count = stmt.slot_count + 1;
                    stmt.stmt_kind[stmt.stmt_count] = Node::LetIn() as Word;
                    stmt.stmt_arg[stmt.stmt_count] = slot;
                    stmt.let_names[stmt.let_count] = stmt.pstmt_name[stmt.pstmt_sp];
                    stmt.scope_slot[stmt.let_count] = slot;
                    // Record the binding's composite type from its value's root construction, so a
                    // later `x.N`/`x.field` access resolves. A tuple allocates a fresh all-Word
                    // `tupledefs` layout (offset i*8, kind Int); a struct reuses its declaration
                    // index. `let_tuple`/`let_struct` default 0 (a scalar or untracked value).
                    stmt.let_tuple[stmt.let_count] = 0;
                    stmt.let_struct[stmt.let_count] = 0;
                    stmt.let_array[stmt.let_count] = 0;
                    stmt.let_array_struct[stmt.let_count] = 0;
                    stmt.let_enum[stmt.let_count] = 0;
                    if stmt.pending_carray_struct > 0 {
                        // An array-of-struct literal: record the element struct index and size so
                        // `a[i].field` arms the struct-array postfix (GetIndex(FlatNested{Struct})).
                        stmt.let_array_struct[stmt.let_count] = stmt.pending_carray_struct;
                        stmt.let_array_size[stmt.let_count] = stmt.pending_carray_size;
                    } else {
                    if stmt.pending_ctuple > 0 {
                        let li = tupledefs.tup_count;
                        tupledefs.tup_estart[li] = tupledefs.tup_ecursor;
                        tupledefs.tup_ecount[li] = stmt.pending_ctuple;
                        for e in 0..stmt.pending_ctuple limit 32 {
                            tupledefs.tup_eoffset[tupledefs.tup_ecursor + e] = e * 8;
                            tupledefs.tup_ekind[tupledefs.tup_ecursor + e] = 3;
                        }
                        tupledefs.tup_ecursor = tupledefs.tup_ecursor + stmt.pending_ctuple;
                        tupledefs.tup_count = li + 1;
                        stmt.let_tuple[stmt.let_count] = li + 1;
                    } else {
                        if stmt.pending_cstruct > 0 {
                            stmt.let_struct[stmt.let_count] = stmt.pending_cstruct;
                        } else {
                            if stmt.pending_carray > 0 {
                                stmt.let_array[stmt.let_count] = stmt.pending_carray;
                            } else {
                                if stmt.pending_cenum > 0 {
                                    stmt.let_enum[stmt.let_count] = stmt.pending_cenum;
                                }
                            }
                        }
                    }
                    }
                    stmt.pending_ctuple = 0;
                    stmt.pending_cstruct = 0;
                    stmt.pending_carray = 0;
                    stmt.pending_carray_struct = 0;
                    stmt.pending_carray_size = 0;
                    stmt.pending_cenum = 0;
                    stmt.let_count = stmt.let_count + 1;
                    stmt.stmt_count = stmt.stmt_count + 1;
                    ops.draining = 0;
                    ops.expect_operand = 1;
                    0
                } else {
                if stmt.pstmt_kind[stmt.pstmt_sp] == 1 {
                    // A scalar data assignment: write the target field's slot.
                    stmt.stmt_kind[stmt.stmt_count] = Node::DataAssignIn() as Word;
                    stmt.stmt_arg[stmt.stmt_count] = stmt.pstmt_arg[stmt.pstmt_sp];
                    stmt.stmt_count = stmt.stmt_count + 1;
                    ops.draining = 0;
                    ops.expect_operand = 1;
                    0
                } else {
                    // An indexed data assignment: the index and value nodes rest on the host
                    // stack (index below, value on top). Emit the IndexStore signal so the
                    // host combines them into a kind-15 node; step_store_finalize then records
                    // the IndexAssignIn statement.
                    da.store_arg = stmt.pstmt_arg[stmt.pstmt_sp];
                    da.store_emit = 1;
                    ops.draining = 0;
                    Node::IndexStore() as Word
                } }
            } else {
                stmt.stmt_kind[stmt.stmt_count] = Node::ExprStmt() as Word;
                stmt.stmt_arg[stmt.stmt_count] = 0;
                stmt.stmt_count = stmt.stmt_count + 1;
                ops.draining = 0;
                ops.expect_operand = 1;
                0
            }
        } else {
        if ops.drain_reason == 1 {
            ops.draining = 0;
            stmt.folding = 1;
            stmt.fold_i = stmt.stmt_count;
            stmt.fold_start = 0;
            stmt.fold_cont = 0;
            0
        } else {
        if ops.drain_reason == 2 {
            branch.if_phase[branch.if_sp - 1] = 2;
            branch.if_stmt_start[branch.if_sp - 1] = stmt.stmt_count;
            branch.if_opbase[branch.if_sp - 1] = ops.opsp;
            branch.if_seq[branch.if_sp - 1] = stmt.open_seq;
            stmt.open_seq = stmt.open_seq + 1;
            stmt.pbase[stmt.pbase_sp] = stmt.stmt_base;
            stmt.pbase_sp = stmt.pbase_sp + 1;
            stmt.stmt_base = stmt.pstmt_sp;
            ops.draining = 0;
            ops.expect_operand = 1;
            0
        } else {
        if ops.drain_reason == 3 {
            ops.draining = 0;
            stmt.folding = 1;
            stmt.fold_i = stmt.stmt_count;
            stmt.fold_start = branch.if_stmt_start[branch.if_sp - 1];
            stmt.fold_cont = 1;
            0
        } else {
        if ops.drain_reason == 4 {
            ops.draining = 0;
            stmt.folding = 1;
            stmt.fold_i = stmt.stmt_count;
            stmt.fold_start = branch.if_stmt_start[branch.if_sp - 1];
            stmt.fold_cont = 2;
            0
        } else {
        if ops.drain_reason == 5 {
            // The loop's low bound is drained; reserve the loop-variable slot.
            forst.for_vslot[forst.for_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            forst.for_phase[forst.for_sp - 1] = 4;
            ops.draining = 0;
            ops.expect_operand = 1;
            0
        } else {
        if ops.drain_reason == 6 {
            // The high bound is drained; reserve the four anonymous loop slots.
            forst.for_end_slot[forst.for_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            forst.for_ctr[forst.for_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            forst.for_cap_slot[forst.for_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            forst.for_oc[forst.for_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            forst.for_phase[forst.for_sp - 1] = 5;
            ops.draining = 0;
            0
        } else {
        if ops.drain_reason == 7 {
            // The loop body is drained; fold its statements around the body value, then
            // start the ForLimit parts emission (fold continuation 3).
            ops.draining = 0;
            stmt.folding = 1;
            stmt.fold_i = stmt.stmt_count;
            stmt.fold_start = forst.for_stmt_start[forst.for_sp - 1];
            stmt.fold_cont = 3;
            0
        } else {
        if ops.drain_reason == 8 {
            // The match scrutinee is drained; reserve its temp slot and read arm patterns.
            mat.match_temp[mat.match_sp - 1] = ps.pcount + stmt.slot_count;
            stmt.slot_count = stmt.slot_count + 1;
            mat.match_phase[mat.match_sp - 1] = 2;
            ops.draining = 0;
            0
        } else {
        if ops.drain_reason == 9 {
            // An arm result is drained; expect the next arm's pattern.
            mat.match_phase[mat.match_sp - 1] = 2;
            ops.draining = 0;
            0
        } else {
        if ops.drain_reason == 10 {
            // The last arm result is drained; build the match.
            mat.match_build = 1;
            ops.draining = 0;
            0
        } else {
            // reason 11: the `when` guard expression is drained; close the guard bracket
            // (its Done) and arm the real body on the next step.
            ps.in_guard = 0;
            ps.arm_pending = 1;
            ops.draining = 0;
            Node::Done() as Word
        } } } } } } } } } } }
    }
}

// Wrap the block's tail in each statement node, last to first, then do the fold
// continuation: the body's Done, a then branch's phase advance, or an else branch's If.
fn step_folding() -> Word {
    if stmt.fold_i > stmt.fold_start {
        stmt.fold_i = stmt.fold_i - 1;
        stmt.stmt_kind[stmt.fold_i] + stmt.stmt_arg[stmt.fold_i] * 64
    } else {
        stmt.stmt_count = stmt.fold_start;
        stmt.folding = 0;
        if stmt.fold_cont > 0 {
            stmt.pbase_sp = stmt.pbase_sp - 1;
            stmt.stmt_base = stmt.pbase[stmt.pbase_sp];
        }
        if stmt.fold_cont == 0 {
            ps.in_body = 0;
            ps.pend_end = 1;
            Node::Done() as Word
        } else {
        if stmt.fold_cont == 1 {
            branch.if_phase[branch.if_sp - 1] = 3;
            0
        } else {
        if stmt.fold_cont == 2 {
            branch.if_sp = branch.if_sp - 1;
            ops.expect_operand = 0;
            stmt.blockform = 1;
            Node::If() as Word
        } else {
            // fold_cont == 3: the `for` body is folded; its value rests on the host stack.
            // Start the ForLimit parts emission.
            forst.for_emit = 1;
            forst.for_emit_i = 0;
            0
        } } }
    }
}

// One step of the body walk: the active sub-state, or the next body token.
fn body_step() -> Word {
    if ops.resolving == 1 {
        step_resolving()
    } else {
    if ops.closing == 1 {
        step_closing()
    } else {
    if structdefs.sc_closing == 1 {
        step_sc_closing()
    } else {
    if da.iclosing == 1 {
        step_iclosing()
    } else {
    if call.cdraining == 1 {
        step_cdraining()
    } else {
    if ops.draining == 1 {
        step_draining()
    } else {
    if stmt.folding == 1 {
        step_folding()
    } else {
    if forst.for_emit == 1 {
        step_for_emit()
    } else {
    if mat.match_build == 1 {
        step_match_build()
    } else {
    if da.store_emit == 1 {
        step_store_finalize()
    } else {
    if call.en_unit == 1 {
        step_enum_unit_finalize()
    } else {
        if ps.cursor >= toks.len {
            ops.draining = 1;
            0
        } else {
            let k = toks.packed[ps.cursor] % 64;
            let v = toks.packed[ps.cursor] / 64;
            ps.cursor = ps.cursor + 1;
            // A pending struct-field-access postfix intercepts the next token here, before the
            // normal dispatch, so the deep `step_dispatch_normal` chain is not deepened.
            if ps.fa_phase >= 1 {
                step_fieldaccess(k, v)
            } else {
            if ps.ta_phase >= 1 {
                step_tupleaccess(k, v)
            } else {
            if ps.sa_phase >= 1 {
                step_structarrayaccess(k, v)
            } else {
            if ps.aa_phase >= 1 {
                step_arrayaccess(k, v)
            } else {
                step_body_dispatch(k, v)
            } } } }
        }
    } } } } } } } } } } }
}

// Reset the body-walk state for a fresh function body.
fn arm_body() -> Word {
    ps.in_body = 1;
    ps.started = 1;
    ops.expect_operand = 1;
    ops.opsp = 0;
    ops.resolving = 0;
    ops.closing = 0;
    ops.draining = 0;
    stmt.let_phase = 0;
    stmt.break_pending = 0;
    stmt.let_count = 0;
    stmt.slot_count = 0;
    stmt.stmt_count = 0;
    stmt.pstmt_sp = 0;
    stmt.stmt_base = 0;
    stmt.pbase_sp = 0;
    stmt.folding = 0;
    stmt.blockform = 0;
    stmt.open_seq = 0;
    branch.if_sp = 0;
    forst.for_sp = 0;
    forst.for_emit = 0;
    forst.forlimit_count = 0;
    mat.match_sp = 0;
    mat.match_build = 0;
    mat.enum_phase = 0;
    mat.mpat_phase = 0;
    da.da_phase = 0;
    da.cda_phase = 0;
    da.as_skip = 0;
    da.idx_sp = 0;
    da.post_index = 0;
    da.iclosing = 0;
    da.fa_index = 0;
    da.store_emit = 0;
    call.call_sp = 0;
    call.al_sp = 0;
    call.en_sp = 0;
    call.en_unit = 0;
    call.tp_sp = 0;
    call.call_phase = 0;
    call.cdraining = 0;
    ps.fa_phase = 0;
    16
}

// Arm the body walk to read a `when` guard expression (reusing arm_body's state
// reset) and emit the GSTART bracket (17). The guard is a single expression the
// walk parses like a body tail; at the body's opening `{` step_body_dispatch drains
// it (drain reason 11), emits the guard's Done, and arms the real body. The guard
// and body share the parameter frame, so no slot is consumed here.
fn arm_guard() -> Word {
    arm_body();
    ps.in_guard = 1;
    17
}

fn header_step(k: Word, v: Word) -> Word {
    if ps.mode == 0 {
        // A `shared`/`private`/`const` modifier or a bare `data` keyword opens a data
        // block; otherwise a function category keyword (`yield`, `loop`, or `fn`).
        if k == 14 {
            ps.dvis = 0;
            ps.mode = 4;
            0
        } else {
        if k == 15 {
            ps.dvis = 1;
            ps.mode = 4;
            0
        } else {
        if k == 16 {
            ps.dvis = 2;
            ps.mode = 4;
            0
        } else {
        if k == 13 {
            ps.dvis = 0;
            ps.mode = 5;
            0
        } else {
        if k == 53 {
            // `enum`: an enum declaration. The name follows in mode 9.
            ps.mode = 9;
            0
        } else {
        if k == 54 {
            // `struct`: a struct type declaration. Its `Name { field: type, ... }` body
            // reuses the data-block field machinery (mode 5 reads the name, 6 the `{`, 7
            // the fields). dvis 3 marks it a struct, so mode 5 emits STRUCTSTART (18)
            // rather than DSTART and commit_field keeps its fields out of the data-field
            // layout table. Generic structs (`Name<...>`) are a later increment.
            ps.dvis = 3;
            ps.mode = 5;
            0
        } else {
        if k == 55 {
            // `trait`: a trait declaration. Emit TRAITSTART and enter the skip machine,
            // which captures each method name as an MNAME.
            ps.mode = 21;
            19
        } else {
        if k == 56 {
            // `impl`: an impl block. Emit IMPLSTART and enter the skip machine over its
            // header (`Type` or `Trait for Type`) and brace-matched body; each method name
            // is captured as an MNAME, exactly as for a trait.
            ps.mode = 21;
            20
        } else {
        if k == 19 {
            // `use`: a native import declaration. Emit USTART and scan the path.
            ps.mode = 8;
            10
        } else {
        if k == 1 andalso v == toks.require_id {
            // A `require` machine-property directive (`require word >= N;`), a lowercase
            // identifier rather than a keyword. Skip it to its `;`; it constrains
            // verification, not the parsed declarations.
            ps.mode = 20;
            0
        } else {
            if k == 5 {
                ps.dkind = 2;
            } else {
            if k == 6 {
                ps.dkind = 3;
            } else {
                ps.dkind = 1;
            } }
            ps.mode = 1;
            0
        } } } } } } } } } }
    } else {
    if ps.mode == 1 {
        if k == 1 {
            ps.pdepth = 0;
            ps.pdone = 0;
            ps.pname = 0;
            ps.ptype = 0;
            ps.rtype = 0;
            ps.arr = 0;
            ps.arr_ret = 0;
            ps.pcount = 0;
            // Capture this function's chunk index (its name's position in `toks.chunks`) so its
            // return type is recorded against it.
            ps.cur_chunk = 0;
            for i in 0..toks.chunk_count limit 256 {
                if toks.chunks[i] == v {
                    ps.cur_chunk = i;
                }
            }
            ps.mode = 2;
            ps.dkind + v * 64
        } else {
            0
        }
    } else {
    if ps.mode == 2 {
        header_sig(k, v)
    } else {
    if ps.mode >= 4 andalso ps.mode <= 7 {
        header_data(k, v)
    } else {
    if ps.mode == 8 {
        header_use(k, v)
    } else {
    if ps.mode == 20 {
        // A `require` directive skip: consume to the `;`.
        if k == 39 {
            ps.mode = 0;
        }
        0
    } else {
    if ps.mode == 21 orelse ps.mode == 22 {
        header_skip_block(k, v)
    } else {
        header_enum(k, v)
    } } } } } } }
}

// A `trait`/`impl` body: mode 21 consumes the header up to the body's opening `{`, then
// mode 22 brace-matches the body and emits END at the matching close brace. Nested braces
// (a method body inside an impl, or a trait default method) are balanced by `idepth`. In
// both a trait and an impl, each `fn` at body depth one arms `pname` so the following
// identifier is captured as a method name (MNAME, dkind 21); the harness routes it to the
// trait's or the impl's method list by the START record. Method parameters, return types,
// and bodies are a later increment.
fn header_skip_block(k: Word, v: Word) -> Word {
    if ps.mode == 21 {
        if k == 2 {
            ps.idepth = 1;
            ps.pname = 0;
            ps.mode = 22;
        }
        0
    } else {
        if k == 2 {
            ps.idepth = ps.idepth + 1;
            0
        } else {
        if k == 3 {
            ps.idepth = ps.idepth - 1;
            if ps.idepth == 0 {
                ps.mode = 0;
                5
            } else {
                0
            }
        } else {
        if ps.idepth == 1 andalso k == 0 {
            // a method signature or definition opens; the next identifier is its name
            ps.pname = 1;
            0
        } else {
        if ps.pname == 1 andalso k == 1 {
            ps.pname = 0;
            21 + v * 64
        } else {
            0
        } } } }
    }
}

// The `use path::name` native import: emit a UPATH per `::`-separated segment; a non-`::`
// token ends the declaration (emit END) and is pushed back to open the next declaration.
fn header_use(k: Word, v: Word) -> Word {
    if k == 1 {
        11 + v * 64
    } else {
    if k == 51 {
        0
    } else {
        ps.cursor = ps.cursor - 1;
        ps.mode = 0;
        5
    } }
}

// The enum declaration modes: 9 the enum name (emit ENUMSTART, dkind 12, and open the
// accumulation), 10 the opening `{`, 11 a variant name (emit EVARIANT, dkind 13, and
// record it with the running discriminant) or `}` ending the enum, 12 an optional `(payload)`,
// an explicit `= N` discriminant, the next variant on `,`, or the `}`, 13 the explicit
// discriminant literal (emit EDISC, dkind 14, and reseed the running discriminant), and 14 the
// variant's payload type list (each type ident sums into the variant's `epayload`, a `)`
// returns to mode 12). The payload scan emits no header record; only the internal size table
// grows, so the declaration record stream is unchanged.
fn header_enum(k: Word, v: Word) -> Word {
    if ps.mode == 9 {
        if k == 1 {
            enums.cur_enum = v;
            enums.next_disc = 0;
            ps.mode = 10;
            12 + v * 64
        } else {
            0
        }
    } else {
    if ps.mode == 10 {
        if k == 2 {
            ps.mode = 11;
        }
        0
    } else {
    if ps.mode == 11 {
        if k == 1 {
            enums.edata[enums.enum_count] = enums.cur_enum;
            enums.evar[enums.enum_count] = v;
            enums.edisc[enums.enum_count] = enums.next_disc;
            enums.epayload[enums.enum_count] = 0;
            enums.evfstart[enums.enum_count] = enums.evfcursor;
            enums.evfcount[enums.enum_count] = 0;
            enums.enum_count = enums.enum_count + 1;
            enums.next_disc = enums.next_disc + 1;
            ps.mode = 12;
            13 + v * 64
        } else {
        if k == 3 {
            ps.mode = 0;
            5
        } else {
            0
        } }
    } else {
    if ps.mode == 12 {
        if k == 7 {
            ps.mode = 14;
            0
        } else {
        if k == 17 {
            ps.mode = 13;
            0
        } else {
        if k == 10 {
            ps.mode = 11;
            0
        } else {
        if k == 3 {
            ps.mode = 0;
            5
        } else {
            0
        } } } }
    } else {
    if ps.mode == 14 {
        if k == 1 {
            // A payload field type: record its flat offset (8 + preceding field sizes) and
            // ScalarKind for a later payload match, then add its size to the running sum.
            let vi = enums.enum_count - 1;
            let fi = enums.evfstart[vi] + enums.evfcount[vi];
            enums.evfoff[fi] = 8 + enums.epayload[vi];
            enums.evfkind[fi] = scalar_kind_of(v);
            enums.evfcount[vi] = enums.evfcount[vi] + 1;
            enums.epayload[vi] = enums.epayload[vi] + type_byte_size(v);
            0
        } else {
        if k == 8 {
            enums.evfcursor = enums.evfstart[enums.enum_count - 1] + enums.evfcount[enums.enum_count - 1];
            ps.mode = 12;
            0
        } else {
            0
        } }
    } else {
        if k == 12 {
            enums.edisc[enums.enum_count - 1] = v;
            enums.next_disc = v + 1;
            ps.mode = 12;
            14 + v * 64
        } else {
            0
        }
    } } } } }
}

// The data-block declaration modes: 4 expect `data` after a modifier, 5 the block name
// (emit DSTART), 6 the opening `{`, 7 the field list (a PARAM per field name, a PTYPE per
// type, an ASIZE for an array field, a const `=` initializer skipped, `}` ends the block).
// DSTART packs the name and visibility as `name * 4 + visibility` (0 shared, 1 private,
// 2 const).
fn header_data(k: Word, v: Word) -> Word {
    if ps.mode == 4 {
        if k == 13 {
            ps.mode = 5;
        }
        0
    } else {
    if ps.mode == 5 {
        if k == 1 {
            ps.pname = 0;
            ps.ptype = 0;
            ps.arr = 0;
            ps.init = 0;
            ps.idepth = 0;
            fields.cur_block = v;
            fields.has_field = 0;
            ps.mode = 6;
            if ps.dvis == 3 {
                // STRUCTSTART: a struct type declaration carrying its name; its fields
                // reuse the data-field scan but are not slotted (see commit_field). Record
                // the name so a body can recognise its `Name { ... }` construction, and open
                // its flat byte-size accumulator (summed per scalar field below).
                structdefs.sd_name[structdefs.sd_count] = v;
                structdefs.sd_bytesize[structdefs.sd_count] = 0;
                structdefs.sd_fstart[structdefs.sd_count] = structdefs.sd_fname_ctr;
                structdefs.sd_fcount[structdefs.sd_count] = 0;
                structdefs.sd_count = structdefs.sd_count + 1;
                18 + v * 64
            } else {
                9 + (v * 4 + ps.dvis) * 64
            }
        } else {
            0
        }
    } else {
    if ps.mode == 6 {
        if k == 2 {
            ps.pname = 1;
            ps.mode = 7;
        }
        0
    } else {
        if ps.init == 1 {
            header_field_skip(k, v)
        } else {
            header_field(k, v)
        }
    } } }
}

// A const field's initializer skip, depth-aware over `()`/`[]`/`{}` so a nested tuple,
// array, or struct initializer is consumed whole; a top-level `,` ends the field and a
// top-level `}` ends the block.
fn header_field_skip(k: Word, v: Word) -> Word {
    if k == 12 andalso ps.idepth == 0 {
        // A top-level integer literal is the const field's value; capture it for the
        // const-field table. A non-literal or nested initializer leaves cur_cval at 0.
        fields.cur_cval = v;
        0
    } else {
    if k == 2 orelse k == 7 orelse k == 41 {
        ps.idepth = ps.idepth + 1;
        0
    } else {
    if k == 8 orelse k == 42 {
        if ps.idepth > 0 {
            ps.idepth = ps.idepth - 1;
        }
        0
    } else {
    if k == 10 {
        if ps.idepth == 0 {
            ps.init = 0;
            ps.pname = 1;
        }
        0
    } else {
    if k == 3 {
        if ps.idepth == 0 {
            // The `}` closes the block while skipping the last field's initializer; commit
            // that field (its captured value) before ending the block.
            commit_field();
            fields.has_field = 0;
            ps.init = 0;
            ps.mode = 0;
            5
        } else {
            ps.idepth = ps.idepth - 1;
            0
        }
    } else {
        0
    } } } } }
}

// Record the pending field's layout in the accumulated table, unless there is no pending
// field or it belongs to a const block (whose fields inline to their value and carry no
// runtime slot). The element-0 slot is the running counter; the counter then advances by
// the field's slot count.
fn commit_field() -> Word {
    // A struct field (dvis 3) is a type member, neither a runtime data slot nor a
    // const-data field, so it is committed to no data-field layout table; only dvis 0/1/2
    // (shared/private/const `data` blocks) accumulate here.
    if fields.has_field == 1 andalso ps.dvis <= 2 {
        if ps.dvis == 2 {
            // A const field inlines to its captured integer value; record it in the
            // const-field table rather than the runtime-slot layout.
            cdata.cblock[cdata.ccount] = fields.cur_block;
            cdata.cfield[cdata.ccount] = fields.cur_field;
            cdata.cval[cdata.ccount] = fields.cur_cval;
            cdata.ccount = cdata.ccount + 1;
        } else {
            fields.fdata[fields.field_count] = fields.cur_block;
            fields.ffield[fields.field_count] = fields.cur_field;
            fields.fbase[fields.field_count] = fields.base_ctr;
            fields.flen[fields.field_count] = fields.cur_len;
            fields.field_count = fields.field_count + 1;
            fields.base_ctr = fields.base_ctr + fields.cur_len;
        }
    }
    0
}

// Record struct field `fidx`'s ScalarKind tag by its type token `v` and return the field's
// flat byte size. A `Word` is eight bytes (kind 3 Int); a `Byte` one (kind 2); a `Bool` one
// (kind 1); a struct-typed field is the already-declared struct's own flat size (declared
// before use, so final here) with kind 0 and `sd_fstruct` set to the nested struct's index + 1
// so a nested field access `p.inner.x` can resolve into it.
fn field_size_and_kind(fidx: Word, v: Word) -> Word {
    if v == toks.word_id {
        structdefs.sd_fkind[fidx] = 3;
        8
    } else {
    if v == toks.byte_id {
        structdefs.sd_fkind[fidx] = 2;
        1
    } else {
    if v == toks.bool_id {
        structdefs.sd_fkind[fidx] = 1;
        1
    } else {
        structdefs.sd_fkind[fidx] = 0;
        structdefs.sd_matchsz = 1;
        for i in 0..structdefs.sd_count limit 64 {
            if structdefs.sd_name[i] == v {
                structdefs.sd_matchsz = structdefs.sd_bytesize[i];
                structdefs.sd_fstruct[fidx] = i + 1;
            }
        }
        structdefs.sd_matchsz
    } } }
}

// A token inside a struct field's tuple type `(T, T, ...)`. A type ident sums its size into the
// running tuple-field size; the `)` records the field's total size, advances the struct byte
// size (so a following field's flat offset is correct), and ends the scan. Emits no record, so
// the declaration record stream is unchanged; only the internal layout gains the field's size.
// The field's ScalarKind is left 0 (a whole-tuple field read would use the FlatNested form, a
// later increment); only sizing is needed here.
fn step_struct_tuple_field(k: Word, v: Word) -> Word {
    if k == Tok::Ident() as Word {
        if ps.dvis == 3 {
            let cur = structdefs.sd_count - 1;
            let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
            let li = structdefs.sd_ftuple[fidx] - 1;
            let base = tupledefs.tup_estart[li];
            let ei = tupledefs.tup_ecount[li];
            tupledefs.tup_eoffset[base + ei] = ps.tf_size;
            tupledefs.tup_ekind[base + ei] = scalar_kind_of(v);
            tupledefs.tup_ecount[li] = ei + 1;
        }
        ps.tf_size = ps.tf_size + type_byte_size(v);
        0
    } else {
    if k == Tok::RParen() as Word {
        if ps.dvis == 3 {
            let cur = structdefs.sd_count - 1;
            let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
            structdefs.sd_fsize[fidx] = ps.tf_size;
            structdefs.sd_fkind[fidx] = 0;
            structdefs.sd_bytesize[cur] = structdefs.sd_bytesize[cur] + ps.tf_size;
            let li = structdefs.sd_ftuple[fidx] - 1;
            tupledefs.tup_ecursor = tupledefs.tup_estart[li] + tupledefs.tup_ecount[li];
        }
        ps.tf = 0;
        0
    } else {
        0
    } }
}

// The field list: a PARAM per field name, a PTYPE per type (with an ASIZE for an array
// field), a const `=` opening an initializer skip, the closing `}` ending the block. Each
// field name commits the previous field to the layout table and opens a new one (default
// length 1); an ASIZE sets its length; the `}` commits the last field. A `(T, T, ...)` field
// type routes through `step_struct_tuple_field` to size the tuple field.
fn header_field(k: Word, v: Word) -> Word {
    if ps.tf == 1 {
        step_struct_tuple_field(k, v)
    } else {
    if k == 1 {
        if ps.arr == 1 {
            ps.arr = 2;
            // A struct array field's element type: capture the element byte size (and, via the
            // helper, its ScalarKind, unused until array-element access lands) to multiply by
            // the length at the `; N`.
            if ps.dvis == 3 {
                let cur = structdefs.sd_count - 1;
                let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
                structdefs.sd_arrelem = field_size_and_kind(fidx, v);
            }
            6 + v * 64
        } else {
        if ps.pname == 1 {
            commit_field();
            fields.cur_field = v;
            fields.cur_len = 1;
            fields.cur_cval = 0;
            fields.has_field = 1;
            // A struct field's name is recorded in declaration order for the construction
            // reorder (see structdefs); data/const fields are not, as they never construct.
            // Its flat byte offset (the running struct size before this field) is recorded
            // here, before its type adds the field's size, so it is set for a scalar and an
            // array field alike.
            if ps.dvis == 3 {
                structdefs.sd_fname[structdefs.sd_fname_ctr] = v;
                structdefs.sd_fname_ctr = structdefs.sd_fname_ctr + 1;
                let cur = structdefs.sd_count - 1;
                structdefs.sd_fcount[cur] = structdefs.sd_fcount[cur] + 1;
                structdefs.sd_foffset[structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1] = structdefs.sd_bytesize[cur];
            }
            ps.pname = 0;
            4 + v * 64
        } else {
        if ps.ptype == 1 {
            ps.ptype = 0;
            if ps.dvis == 3 {
                // A scalar field: add its size (the offset was set at the field name), with
                // field_size_and_kind also recording its ScalarKind, and record the field size.
                let cur = structdefs.sd_count - 1;
                let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
                structdefs.sd_fsize[fidx] = field_size_and_kind(fidx, v);
                structdefs.sd_bytesize[cur] = structdefs.sd_bytesize[cur] + structdefs.sd_fsize[fidx];
            }
            6 + v * 64
        } else {
            0
        } }
        }
    } else {
    if k == 41 {
        if ps.ptype == 1 {
            ps.ptype = 0;
            ps.arr = 1;
        }
        0
    } else {
    if k == 7 {
        // A `(` opening a struct field's tuple type `(T, T, ...)`: scan its element types in
        // `step_struct_tuple_field` to size the field and record its element layout (a `tupledefs`
        // entry bound to the field via `sd_ftuple`, so a nested `s.p.N` access reads element N).
        if ps.ptype == 1 {
            ps.ptype = 0;
            ps.tf = 1;
            ps.tf_size = 0;
            if ps.dvis == 3 {
                let cur = structdefs.sd_count - 1;
                let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
                let li = tupledefs.tup_count;
                tupledefs.tup_estart[li] = tupledefs.tup_ecursor;
                tupledefs.tup_ecount[li] = 0;
                tupledefs.tup_count = li + 1;
                structdefs.sd_ftuple[fidx] = li + 1;
            }
        }
        0
    } else {
    if k == 12 {
        if ps.arr == 2 {
            ps.arr = 0;
            fields.cur_len = v;
            // A struct array field's length: the field's flat size is element_size * length,
            // recorded per field for a later FlatNested element access.
            if ps.dvis == 3 {
                let cur = structdefs.sd_count - 1;
                let fidx = structdefs.sd_fstart[cur] + structdefs.sd_fcount[cur] - 1;
                structdefs.sd_fsize[fidx] = structdefs.sd_arrelem * v;
                structdefs.sd_bytesize[cur] = structdefs.sd_bytesize[cur] + structdefs.sd_fsize[fidx];
            }
            8 + v * 64
        } else {
            0
        }
    } else {
    if k == 9 {
        ps.ptype = 1;
        0
    } else {
    if k == 10 {
        ps.pname = 1;
        0
    } else {
    if k == 17 {
        ps.init = 1;
        ps.idepth = 0;
        0
    } else {
    if k == 3 {
        commit_field();
        fields.has_field = 0;
        ps.mode = 0;
        5
    } else {
        0
    } } } } } } } } }
}

// Mode 2: the signature scan, ending when the first `{` at depth zero arms the body walk.
fn header_sig(k: Word, v: Word) -> Word {
    if ps.rtts == 1 {
        // Inside a return-type tuple `-> (T, T, ...)`: count its all-Word elements for the chunk.
        step_ret_tuple_type(k, v)
    } else {
    if ps.tts == 1 {
        // Inside a tuple parameter type `(T, T, ...)`: the element types feed the tuple layout.
        step_tuple_type(k, v)
    } else {
    if k == 1 {
        if ps.arr == 1 {
            ps.arr = 2;
            if ps.arr_ret == 0 {
                // An array PARAMETER `xs: [T; N]`. If the element type names a declared struct,
                // record the struct's declaration index (plus one) and flat byte size so a body
                // `ps[i].field` extracts element i as a nested struct; otherwise record the element
                // ScalarKind (plus one) so `xs[i]` reads a scalar. A return-type array is not
                // recorded (no body access resolves through it).
                ps.found_flag = 0;
                for i in 0..structdefs.sd_count limit 64 {
                    if structdefs.sd_name[i] == v {
                        ps.found_flag = 1;
                        ps.parray_struct[ps.pcount - 1] = i + 1;
                        ps.parray_size[ps.pcount - 1] = structdefs.sd_bytesize[i];
                    }
                }
                if ps.found_flag == 0 {
                    ps.parray[ps.pcount - 1] = scalar_kind_of(v) + 1;
                }
                6 + v * 64
            } else {
                // A scalar array RETURN `-> [T; N]`: record the element ScalarKind (plus one) so a
                // `let a = f(); a[i]` bound to the call arms array-element access. A struct-element
                // array return is left unrecorded (a later extension).
                ps.found_flag = 0;
                for i in 0..structdefs.sd_count limit 64 {
                    if structdefs.sd_name[i] == v {
                        ps.found_flag = 1;
                    }
                }
                if ps.found_flag == 0 {
                    chunkret.ret_array[ps.cur_chunk] = scalar_kind_of(v) + 1;
                }
                7 + v * 64
            }
        } else {
        if ps.pdepth == 1 {
            if ps.pname == 1 {
                ps.pname = 0;
                ps.pnames[ps.pcount] = v;
                // Default this parameter to non-struct and non-tuple; the type identifier or `(`
                // tuple annotation that follows overrides it.
                ps.pstruct[ps.pcount] = 0;
                ps.ptuple[ps.pcount] = 0;
                ps.penum[ps.pcount] = 0;
                ps.parray[ps.pcount] = 0;
                ps.parray_struct[ps.pcount] = 0;
                ps.pcount = ps.pcount + 1;
                4 + v * 64
            } else {
            if ps.ptype == 1 {
                ps.ptype = 0;
                // Record whether this parameter's type names a declared struct (index + 1),
                // so a body `p.field` access can resolve the field. A scalar type leaves 0.
                for i in 0..structdefs.sd_count limit 64 {
                    if structdefs.sd_name[i] == v {
                        ps.pstruct[ps.pcount - 1] = i + 1;
                    }
                }
                // Record whether this parameter's type names a declared enum (its name id + 1), so
                // a `match` over the parameter lowers to the IsEnum virtual loop.
                for i in 0..enums.enum_count limit 256 {
                    if enums.edata[i] == v {
                        ps.penum[ps.pcount - 1] = v + 1;
                    }
                }
                6 + v * 64
            } else {
                0
            } }
        } else {
            if ps.rtype == 1 {
                ps.rtype = 0;
                // Record a struct return type for the current chunk, so a `let x = f()` bound to a
                // call of this function arms `x.field` access.
                for i in 0..structdefs.sd_count limit 64 {
                    if structdefs.sd_name[i] == v {
                        chunkret.ret_struct[ps.cur_chunk] = i + 1;
                    }
                }
                // Record an enum return type, so a `let e = f(); match e` lowers to IsEnum.
                for i in 0..enums.enum_count limit 256 {
                    if enums.edata[i] == v {
                        chunkret.ret_enum[ps.cur_chunk] = v + 1;
                    }
                }
                7 + v * 64
            } else {
                0
            }
        } }
    } else {
    if k == 41 {
        // A `[` opening an array type. `LBracket` is token class 41; the array element type
        // (k==1 with `ps.arr == 1`) and the size close (the `IntLit`, k==12 with `ps.arr == 2`)
        // complete it. A parameter array records its element ScalarKind (see the k==1 branch);
        // a return-type array is consumed but not recorded (no body access resolves through it).
        if ps.ptype == 1 {
            ps.ptype = 0;
            ps.arr_ret = 0;
            ps.arr = 1;
        } else {
            if ps.rtype == 1 {
                ps.rtype = 0;
                ps.arr_ret = 1;
                ps.arr = 1;
            }
        }
        0
    } else {
    if k == 12 {
        if ps.arr == 2 {
            ps.arr = 0;
            8 + v * 64
        } else {
            0
        }
    } else {
    if k == 7 {
        if ps.ptype == 1 andalso ps.pdepth == 1 {
            // A tuple parameter type `(T, T, ...)`: open a fresh tuple layout entry, bind it to the
            // current parameter, and scan its element types in `step_tuple_type`. The outer `(`
            // stays at pdepth 1; the tuple's own `(`/`)` never touch pdepth.
            ps.ptuple[ps.pcount - 1] = tupledefs.tup_count + 1;
            tupledefs.tup_estart[tupledefs.tup_count] = tupledefs.tup_ecursor;
            tupledefs.tup_ecount[tupledefs.tup_count] = 0;
            tupledefs.tup_count = tupledefs.tup_count + 1;
            ps.tts = 1;
            ps.tts_off = 0;
            0
        } else {
        if ps.rtype == 1 andalso ps.pdepth == 0 {
            // A return-type tuple `-> (T, T, ...)`: count its all-Word elements in
            // `step_ret_tuple_type` (no pdepth change; the tuple's `(`/`)` are consumed by rtts).
            ps.rtts = 1;
            ps.rtts_count = 0;
            ps.rtts_allword = 1;
            0
        } else {
            ps.pdepth = ps.pdepth + 1;
            if ps.pdepth == 1 {
                if ps.pdone == 0 {
                    ps.pname = 1;
                }
            }
            0
        } }
    } else {
    if k == 8 {
        ps.pdepth = ps.pdepth - 1;
        if ps.pdepth == 0 {
            ps.pdone = 1;
            ps.rtype = 1;
        }
        0
    } else {
    if k == 9 {
        if ps.pdepth == 1 {
            ps.ptype = 1;
        }
        0
    } else {
    if k == 10 {
        if ps.pdepth == 1 {
            if ps.pdone == 0 {
                ps.pname = 1;
            }
        }
        0
    } else {
    if k == 2 {
        if ps.pdepth == 0 {
            arm_body()
        } else {
            0
        }
    } else {
        // Both `->` and `when` are the catch-all Tok 4. The arrow arrives before the
        // return type (rtype still armed); `when` after it (rtype cleared), so a Tok 4
        // at depth zero with rtype cleared opens the guard.
        if k == 4 andalso ps.rtype == 0 andalso ps.pdepth == 0 {
            arm_guard()
        } else {
            0
        }
    } } } } } } } } } }
}

fn step() -> Word {
    if ps.pend_end == 1 {
        ps.pend_end = 0;
        ps.mode = 0;
        5
    } else {
    if ps.arm_pending == 1 {
        // The guard just closed; arm the real body (emit BSTART) before its tokens.
        ps.arm_pending = 0;
        arm_body()
    } else {
    if ps.in_body == 1 {
        body_step()
    } else {
        if ps.cursor >= toks.len {
            // A `use` running to end-of-input has no closing delimiter, so it is closed
            // here (END) before DONE; otherwise the stream is exhausted.
            if ps.mode == 8 {
                ps.mode = 0;
                5
            } else {
                15
            }
        } else {
            let k = toks.packed[ps.cursor] % 64;
            let v = toks.packed[ps.cursor] / 64;
            ps.cursor = ps.cursor + 1;
            header_step(k, v)
        }
    } } }
}

loop main(resume: Word) -> Word {
    yield step()
}
