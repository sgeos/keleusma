msgstr "`shell::writeln_err`、`shell::write_err`"

#: src/AUTOMATION_SCRIPTING.md:63
msgid "Log-shaped output to stderr."
msgstr "標準エラー出力へのログ形式の出力。"

#: src/AUTOMATION_SCRIPTING.md:64
msgid "`shell::arg`, `shell::arg_count`"
msgstr "`shell::arg`、`shell::arg_count`"

#: src/AUTOMATION_SCRIPTING.md:64
msgid "The script's own arguments."
msgstr "スクリプト自身の引数。"

#: src/AUTOMATION_SCRIPTING.md:65
msgid "`shell::exit(code)`"
msgstr "`shell::exit(code)`"

#: src/AUTOMATION_SCRIPTING.md:65
