root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.{rs,kel}]
indent_size = 4
max_line_length = 100

[*.{md,toml,yaml,yml,json}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{vim,el}]
indent_size = 2
